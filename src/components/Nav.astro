---
const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo">
      <svg
        viewBox="0 0 400 400"
        fill="none"
        width="36"
        height="36"
        style="border-radius:7px;overflow:hidden;"
      >
        <rect width="400" height="400" fill="#1C1916"></rect>
        <text
          text-anchor="middle"
          x="82"
          y="276"
          font-family="JetBrains Mono,monospace"
          font-size="210"
          font-weight="700"
          fill="#C1634F">&#123;</text
        >
        <text
          text-anchor="middle"
          x="318"
          y="276"
          font-family="JetBrains Mono,monospace"
          font-size="210"
          font-weight="700"
          fill="#C1634F">&#125;</text
        >
        <text
          text-anchor="middle"
          x="153"
          y="256"
          font-family="JetBrains Mono,monospace"
          font-size="82"
          font-weight="800"
          fill="#B5A99A">P</text
        >
        <text
          text-anchor="middle"
          x="200"
          y="256"
          font-family="JetBrains Mono,monospace"
          font-size="82"
          font-weight="800"
          fill="#D4A96A">D</text
        >
        <text
          text-anchor="middle"
          x="247"
          y="256"
          font-family="JetBrains Mono,monospace"
          font-size="82"
          font-weight="800"
          fill="#B5A99A">Q</text
        >
        <circle cx="310" cy="68" r="11" fill="#FF6B35" opacity="0.9"></circle>
        <circle cx="334" cy="68" r="7" fill="#D4A96A" opacity="0.7"></circle>
      </svg>
      <span class="nav-brand">
        <span class="brand-phils">Phils</span><span class="brand-dev">Dev</span
        ><span class="brand-quest">Quest</span>
      </span>
    </a>

    <!-- Links -->
    <ul class="nav-links">
      <li><a href="/" class={currentPath === "/" ? "active" : ""}>Start</a></li>
      <li>
        <a
          href="/tutorials"
          class={currentPath.startsWith("/tutorials") ? "active" : ""}
          >Tutorials</a>
      </li>
      <li>
        <a href="/blog" class={currentPath.startsWith("/blog") ? "active" : ""}
          >Blog</a>
      </li>
      <li>
        <a
          href="/tools"
          class={currentPath.startsWith("/tools") ? "active" : ""}>Tools</a>
      </li>
      <li>
        <a
          href="/ueber-mich"
          class={currentPath.startsWith("/ueber-mich") ? "active" : ""}
          >Über mich</a>
      </li>
    </ul>

    <!-- CTA Button -->
    <a href="#newsletter" class="nav-cta">Newsletter →</a>
  </div>
</nav>

<style>
  .nav {
    background: var(--pdq-bg-elevated);
    border-bottom: 1px solid var(--pdq-border-default);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-brand {
    font-family: var(--pdq-font-mono);
    font-weight: 700;
    font-size: 1rem;
  }

  .brand-phils {
    color: var(--pdq-text-disabled);
  }
  .brand-dev {
    color: var(--pdq-text-secondary);
  }
  .brand-quest {
    color: var(--pdq-terracotta);
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 1.75rem;
  }

  .nav-links a {
    color: var(--pdq-text-secondary);
    font-size: 0.875rem;
    font-weight: 600;
    transition: color 0.2s;
    text-decoration: none;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--pdq-sand);
  }

  .nav-cta {
    background: var(--pdq-orange);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.45rem 1rem;
    border-radius: 6px;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .nav-cta:hover {
    opacity: 0.85;
    color: #fff;
  }
</style>
