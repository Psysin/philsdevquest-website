---
const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="logo">
      <span class="brace">{</span><span class="sp"></span><span class="p">P</span><span class="d">D</span><span class="q">Q</span><span class="sp"></span><span class="brace">}</span>
    </a>

    <!-- Desktop Links -->
    <ul class="nav-links">
      <li><a href="/ueber-mich" class={currentPath.startsWith("/ueber-mich") ? "active" : ""}>Über mich</a></li>
      <li><a href="/blog" class={currentPath.startsWith("/blog") ? "active" : ""}>Blog</a></li>
      <li><a href="/devlog" class={currentPath.startsWith("/devlog") ? "active" : ""}>Devlog</a></li>
      <li><a href="/newsletter" class={currentPath.startsWith("/newsletter") ? "active" : ""}>Newsletter</a></li>
    </ul>

    <!-- Theme Toggle -->
    <button class="theme-toggle" id="theme-toggle" aria-label="Dark Mode umschalten" title="Dark Mode umschalten">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>

    <!-- Desktop CTA -->
    <a href="/newsletter" class="nav-cta">Abonnieren</a>

    <!-- Mobile Hamburger -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menü öffnen">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="nav-mobile" id="nav-mobile">
    <ul class="nav-mobile-links">
      <li><a href="/" class={currentPath === "/" ? "active" : ""}>Start</a></li>
      <li><a href="/ueber-mich" class={currentPath.startsWith("/ueber-mich") ? "active" : ""}>Über mich</a></li>
      <li><a href="/blog" class={currentPath.startsWith("/blog") ? "active" : ""}>Blog</a></li>
      <li><a href="/devlog" class={currentPath.startsWith("/devlog") ? "active" : ""}>Devlog</a></li>
      <li><a href="/newsletter" class={currentPath.startsWith("/newsletter") ? "active" : ""}>Newsletter</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    background: rgba(251,247,241,0.82);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--pdq-border-subtle);
    position: sticky;
    top: 0;
    z-index: 100;
    height: 56px;
  }

  .nav-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* { PDQ } text logo */
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-family: var(--pdq-font-mono);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.01em;
    cursor: pointer;
    user-select: none;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo .brace { color: var(--pdq-terracotta); }
  .logo .p, .logo .q { color: var(--pdq-text-secondary); font-weight: 800; }
  .logo .d { color: var(--pdq-sand); font-weight: 800; }
  .logo .sp { display: inline-block; width: 4px; }

  /* Desktop Links */
  .nav-links {
    list-style: none;
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .nav-links a {
    display: block;
    font-size: 13px;
    color: var(--pdq-text-secondary);
    padding: 8px 14px;
    border-radius: 999px;
    transition: color .2s, background .2s;
    letter-spacing: 0.01em;
    text-decoration: none;
  }
  .nav-links a:hover { color: var(--pdq-text-primary); }
  .nav-links a.active {
    color: var(--pdq-text-primary);
    background: rgba(26,21,18,0.05);
  }

  .nav-cta {
    font-size: 12px;
    font-weight: 500;
    padding: 7px 16px;
    border-radius: 999px;
    background: var(--pdq-terracotta);
    color: #fff;
    text-decoration: none;
    flex-shrink: 0;
    transition: background .2s;
  }
  .nav-cta:hover { background: #A04A38; color: #fff; }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--pdq-text-secondary);
    border-radius: 2px;
    transition: all 0.3s;
  }
  .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile Menu */
  .nav-mobile {
    display: none;
    border-top: 1px solid var(--pdq-border-subtle);
    background: rgba(251,247,241,0.98);
  }
  .nav-mobile.open { display: block; }

  .nav-mobile-links {
    list-style: none;
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .nav-mobile-links a {
    display: block;
    padding: 0.65rem 0;
    color: var(--pdq-text-secondary);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid var(--pdq-border-subtle);
    transition: color 0.2s;
  }
  .nav-mobile-links a:hover,
  .nav-mobile-links a.active {
    color: var(--pdq-terracotta);
  }

  /* Theme Toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid var(--pdq-border-default);
    background: transparent;
    color: var(--pdq-text-muted);
    cursor: pointer;
    transition: color .2s, border-color .2s, background .2s;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    color: var(--pdq-text-primary);
    border-color: var(--pdq-border-strong);
    background: var(--pdq-bg-overlay);
  }

  /* Sonne im Light-Mode zeigen, Mond im Dark-Mode */
  .icon-moon { display: none; }
  [data-theme="dark"] .icon-moon { display: block; }
  [data-theme="dark"] .icon-sun  { display: none; }

  @media (max-width: 720px) {
    .nav-links { display: none !important; }
    .nav-cta { display: none !important; }
    .nav-hamburger { display: flex; }
  }
</style>

<script>
  const hamburger = document.getElementById("nav-hamburger");
  const mobileMenu = document.getElementById("nav-mobile");

  hamburger?.addEventListener("click", () => {
    hamburger.classList.toggle("open");
    mobileMenu?.classList.toggle("open");
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      hamburger?.classList.remove("open");
      mobileMenu.classList.remove("open");
    });
  });

  // Theme Toggle
  const themeToggle = document.getElementById("theme-toggle");
  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    if (isDark) {
      document.documentElement.removeAttribute("data-theme");
      try { localStorage.setItem("pdq-theme", "light"); } catch(_) {}
    } else {
      document.documentElement.setAttribute("data-theme", "dark");
      try { localStorage.setItem("pdq-theme", "dark"); } catch(_) {}
    }
  });
</script>
