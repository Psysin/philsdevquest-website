---
// src/components/NewsletterForm.astro
// Props:
//   variant — "hero" | "section"

interface Props {
  variant?: "hero" | "section";
}
const { variant = "section" } = Astro.props;
---

{
  variant === "hero" ? (
    <div class="nlf nlf--hero">
      <form data-nlf>
        <div class="nlf-row">
          <input
            type="email"
            name="email"
            placeholder="du@example.com"
            required
            autocomplete="email"
            class="nlf-input"
            aria-label="E-Mail-Adresse"
          />
          <button type="submit" class="nlf-btn">
            <span class="nlf-btn__text">Dabei sein</span>
            <span class="nlf-btn__loading" hidden>…</span>
          </button>
        </div>
        <input
          type="text"
          name="firstname"
          placeholder="Dein Vorname (optional)"
          autocomplete="given-name"
          class="nlf-input nlf-input--name"
        />
      </form>
      <label class="nlf-consent">
        <input type="checkbox" required />
        <span>
          Ich stimme zu, den Newsletter zu erhalten.{" "}
          <a href="/datenschutz">Datenschutz</a>
        </span>
      </label>
      <p class="nlf-hint">Monatlich · Code-Quiz inklusive · Jederzeit abbestellbar</p>
      <p class="nlf-feedback" data-feedback hidden />
    </div>
  ) : (
    <div class="nlf nlf--section">
      <div class="nlf--section__inner">
        <p class="nlf-kicker">PhilsDevQuest Monthly</p>
        <h2 class="nlf-headline">
          Komm mit auf die Reise.
        </h2>
        <p class="nlf-description">
          Einmal im Monat schick ich dir, was ich gelernt hab, woran ich feststecke und das Code-Quiz des Monats. Kurz, ehrlich, ohne Belehrung.
        </p>
        <form data-nlf>
          <div class="nlf-row">
            <input
              type="email"
              name="email"
              placeholder="du@example.com"
              required
              autocomplete="email"
              class="nlf-input"
              aria-label="E-Mail-Adresse"
            />
            <button type="submit" class="nlf-btn">
              <span class="nlf-btn__text">Dabei sein</span>
              <span class="nlf-btn__loading" hidden>…</span>
            </button>
          </div>
          <input
            type="text"
            name="firstname"
            placeholder="Dein Vorname (optional)"
            autocomplete="given-name"
            class="nlf-input nlf-input--name"
          />
        </form>
        <label class="nlf-consent">
          <input type="checkbox" required />
          <span>
            Ich stimme zu, den Newsletter zu erhalten.{" "}
            <a href="/datenschutz">Datenschutz</a>
          </span>
        </label>
        <p class="nlf-feedback" data-feedback hidden />
        <div class="nlf-meta">
          <span>Monatlich</span>
          <span>Code-Quiz inklusive</span>
          <span>Jederzeit abbestellbar</span>
        </div>
      </div>
    </div>
  )
}

<script>
  document.querySelectorAll("[data-nlf]").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const container = form.closest(".nlf");
      const emailInput = form.querySelector("input[name='email']");
      const firstInput = form.querySelector("input[name='firstname']");
      const consent = container.querySelector(".nlf-consent input");
      const btnText = form.querySelector(".nlf-btn__text");
      const btnLoading = form.querySelector(".nlf-btn__loading");
      const feedback = container.querySelector("[data-feedback]");
      const btn = form.querySelector("button");

      if (!consent.checked) {
        feedback.textContent = "⚠️ Bitte stimme der Datenschutzerklärung zu.";
        feedback.className = "nlf-feedback nlf-feedback--error";
        feedback.hidden = false;
        return;
      }

      btnText.hidden = true;
      btnLoading.hidden = false;
      btn.disabled = true;
      feedback.hidden = true;

      try {
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            email: emailInput.value.trim(),
            firstname: firstInput?.value.trim() || "",
          }),
        });
        const data = await res.json();

        if (data.success) {
          form.hidden = true;
          container.querySelector(".nlf-consent").hidden = true;
          feedback.textContent = "Danke, dass du mitliest. Check dein Postfach — da wartet eine Bestätigung.";
          feedback.className = "nlf-feedback nlf-feedback--success";
          feedback.hidden = false;
        } else {
          feedback.textContent =
            "⚠️ " + (data.error || "Etwas ist schiefgelaufen.");
          feedback.className = "nlf-feedback nlf-feedback--error";
          feedback.hidden = false;
          btnText.hidden = false;
          btnLoading.hidden = true;
          btn.disabled = false;
        }
      } catch {
        feedback.textContent =
          "⚠️ Verbindungsfehler. Bitte versuche es erneut.";
        feedback.className = "nlf-feedback nlf-feedback--error";
        feedback.hidden = false;
        btnText.hidden = false;
        btnLoading.hidden = true;
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  .nlf form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .nlf-row {
    display: flex;
    gap: 8px;
    max-width: 480px;
    background: var(--pdq-bg-overlay);
    border: 1px solid var(--pdq-border-default);
    border-radius: 999px;
    padding: 6px;
    transition: border-color .2s, box-shadow .2s;
  }
  .nlf-row:focus-within {
    border-color: var(--pdq-terracotta);
    box-shadow: 0 0 0 4px rgba(184,85,64,0.12);
  }

  .nlf-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--pdq-text-primary);
    font-family: var(--pdq-font-mono);
    font-size: 14px;
    padding: 10px 16px;
  }
  .nlf-input::placeholder { color: var(--pdq-text-muted); }

  .nlf-input--name {
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--pdq-border-default);
    border-radius: 0;
    padding: 8px 4px;
    font-size: 13px;
    max-width: 480px;
    display: none;
  }

  .nlf-btn {
    background: var(--pdq-orange);
    border: none;
    border-radius: 999px;
    color: #fff;
    cursor: pointer;
    font-family: var(--pdq-font-mono);
    font-size: 13px;
    font-weight: 500;
    padding: 10px 22px;
    transition: background .2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nlf-btn:hover:not(:disabled) { background: var(--pdq-orange-dark); }
  .nlf-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .nlf-consent {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    color: var(--pdq-text-muted);
    cursor: pointer;
    max-width: 480px;
    margin-top: 4px;
  }
  .nlf-consent input {
    margin-top: 2px;
    accent-color: var(--pdq-sand);
    flex-shrink: 0;
  }
  .nlf-consent a { color: var(--pdq-terracotta); }

  .nlf-hint {
    font-family: var(--pdq-font-mono);
    font-size: 11.5px;
    color: var(--pdq-text-muted);
    margin: 4px 0 0;
  }

  .nlf-feedback {
    font-family: var(--pdq-font-mono);
    font-size: 13.5px;
    padding: 14px 18px;
    border-radius: 14px;
    margin: 8px 0 0;
    max-width: 480px;
  }
  .nlf-feedback--success {
    background: rgba(76,134,64,0.08);
    color: #4C8640;
    border: 1px solid rgba(76,134,64,0.22);
  }
  .nlf-feedback--error {
    background: rgba(184,85,64,0.08);
    color: var(--pdq-terracotta);
    border: 1px solid rgba(184,85,64,0.22);
  }

  /* Hero variant */
  .nlf--hero {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Section variant */
  .nlf--section {
    background: var(--pdq-bg-elevated);
    border-radius: 28px;
    padding: 72px 48px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 4px rgba(26,21,18,0.04), 0 24px 60px -20px rgba(26,21,18,0.14);
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .nlf--section__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .nlf--section .nlf-row {
    justify-content: center;
  }

  .nlf--section .nlf-consent {
    text-align: left;
    justify-content: center;
  }

  .nlf-kicker {
    font-family: var(--pdq-font-hand);
    font-weight: 600;
    font-size: 26px;
    color: var(--pdq-terracotta);
    margin: 0;
  }

  .nlf-headline {
    font-family: var(--pdq-font-mono);
    font-weight: 600;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--pdq-text-primary);
    margin: 0;
  }

  .nlf-description {
    font-size: 16px;
    color: var(--pdq-text-secondary);
    line-height: 1.65;
    max-width: 480px;
    margin: 0;
  }

  .nlf-meta {
    display: flex;
    gap: 18px;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 11.5px;
    color: var(--pdq-text-muted);
    margin-top: 8px;
  }
  .nlf-meta span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .nlf-meta span::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--pdq-sand);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .nlf--section {
      padding: 48px 24px;
      border-radius: 20px;
    }
    .nlf-row {
      flex-direction: column;
      border-radius: 14px;
      padding: 8px;
    }
    .nlf-btn {
      border-radius: 10px;
      width: 100%;
      padding: 12px;
    }
  }
</style>
