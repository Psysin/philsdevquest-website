---
/**
 * AdSlot.astro — Wiederverwendbare AdSense-Komponente
 *
 * Props:
 *   slotId  — AdSense Ad-Unit ID (z.B. "1234567890")
 *   label   — Optionaler Label für Entwickler-Ansicht (z.B. "Position 1 – Top")
 */
interface Props {
  slotId: string;
  label?: string;
}

const { slotId, label } = Astro.props;
const publisherId = "ca-pub-1972800950201366";
---

<div class="ad-slot">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={publisherId}
    data-ad-slot={slotId}
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script is:inline>
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>

<style>
  .ad-slot {
    width: 100%;
    margin: 1.5rem 0;
    min-height: 90px; /* Verhindert Layout-Shift */
  }
</style>
