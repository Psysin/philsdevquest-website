---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allNews = await getCollection("news");
  return allNews.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const categoryColors: Record<string, string> = {
  Python: "badge-python",
  Godot: "badge-godot",
  Coding: "badge-coding",
};

const dateFormatted = entry.data.date.toLocaleDateString("de-DE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.og_image}
>
  <main class="news-detail">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/news/">← Alle News</a>
    </nav>

    <!-- Header -->
    <header class="article-header">
      <div class="article-meta">
        <span class={`badge ${categoryColors[entry.data.category] ?? ""}`}>
          {entry.data.category}
        </span>
        {
          entry.data.source && (
            <span class="source-label">via {entry.data.source}</span>
          )
        }
        <span class="article-date">{dateFormatted}</span>
      </div>

      <h1>{entry.data.title}</h1>
      <p class="article-summary">{entry.data.summary}</p>

      {
        entry.data.tags && entry.data.tags.length > 0 && (
          <div class="tag-list">
            {entry.data.tags.map((tag: string) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <!-- Beitragsbild -->
    {
      entry.data.og_image && (
        <div class="article-hero-image">
          <img
            src={entry.data.og_image}
            alt={entry.data.title}
            loading="lazy"
          />
        </div>
      )
    }

    <!-- Trennlinie -->
    <hr class="article-divider" />

    <!-- Artikel-Body (von n8n generierter Langtext) -->
    <article class="article-body prose">
      <Content />
    </article>

    <!-- Quelle -->
    <div class="source-box">
      <span class="source-box-label">Originalquelle</span>
      {
        entry.data.source && (
          <span class="source-box-name">{entry.data.source}</span>
        )
      }
      <a
        href={entry.data.url}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-source"
      >
        Zum Originalartikel →
      </a>
    </div>

    <!-- Back -->
    <div class="back-link">
      <a href="/news/">← Zurück zu allen News</a>
    </div>
  </main>
</BaseLayout>

<style>
  .news-detail {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    font-family: var(--pdq-font-mono);
    font-size: 0.85rem;
    color: var(--pdq-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--pdq-orange);
  }

  /* Header */
  .article-header {
    margin-bottom: 2rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .source-label {
    font-family: var(--pdq-font-mono);
    font-size: 0.8rem;
    color: var(--pdq-text-muted);
  }

  .article-date {
    font-family: var(--pdq-font-mono);
    font-size: 0.8rem;
    color: var(--pdq-text-muted);
    margin-left: auto;
  }

  .article-header h1 {
    font-family: var(--pdq-font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--pdq-text-primary);
    line-height: 1.35;
    margin: 0 0 1rem;
  }

  .article-summary {
    font-family: var(--pdq-font-mono);
    font-size: 1rem;
    color: var(--pdq-text-secondary);
    line-height: 1.7;
    margin: 0 0 1.25rem;
    padding-left: 1rem;
    border-left: 3px solid var(--pdq-sand);
  }

  /* Tags */
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    color: var(--pdq-text-muted);
    background: var(--pdq-bg-overlay);
    border: 1px solid var(--pdq-border-subtle);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  /* Beitragsbild */
  .article-hero-image {
    margin-bottom: 2rem;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--pdq-border-default);
  }

  .article-hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Divider */
  .article-divider {
    border: none;
    border-top: 1px solid var(--pdq-border-default);
    margin: 2rem 0;
  }

  /* Prose (Artikel-Body) */
  .prose {
    font-family: var(--pdq-font-mono);
    font-size: 0.95rem;
    color: var(--pdq-text-secondary);
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--pdq-text-primary);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--pdq-text-primary);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) {
    margin: 0 0 1.1rem;
  }

  .prose :global(strong) {
    color: var(--pdq-text-primary);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--pdq-orange);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(code) {
    background: var(--pdq-bg-overlay);
    border: 1px solid var(--pdq-border-subtle);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875em;
    color: var(--pdq-terracotta-light);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--pdq-terracotta);
    margin: 1.5rem 0;
    padding: 0.5rem 1rem;
    color: var(--pdq-text-muted);
    font-style: italic;
  }

  /* Source Box */
  .source-box {
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--pdq-bg-elevated);
    border: 1px solid var(--pdq-border-default);
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .source-box-label {
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pdq-text-muted);
  }

  .source-box-name {
    font-family: var(--pdq-font-mono);
    font-size: 0.875rem;
    color: var(--pdq-text-secondary);
    font-weight: 600;
  }

  .btn-source {
    margin-left: auto;
    display: inline-block;
    padding: 0.6rem 1.25rem;
    background: var(--pdq-orange);
    color: #fff;
    font-family: var(--pdq-font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.15s;
  }

  .btn-source:hover {
    background: var(--pdq-orange-dark);
  }

  /* Back Link */
  .back-link {
    margin-top: 2.5rem;
  }

  .back-link a {
    font-family: var(--pdq-font-mono);
    font-size: 0.85rem;
    color: var(--pdq-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link a:hover {
    color: var(--pdq-orange);
  }

  /* Badges */
  .badge {
    font-family: var(--pdq-font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .badge-python {
    background: var(--pdq-terracotta-dim);
    color: var(--pdq-terracotta-light);
    border: 1px solid rgba(193, 99, 79, 0.3);
  }

  .badge-godot {
    background: var(--pdq-sand-dim);
    color: var(--pdq-sand);
    border: 1px solid rgba(212, 169, 106, 0.3);
  }

  .badge-coding {
    background: rgba(255, 107, 53, 0.1);
    color: var(--pdq-orange);
    border: 1px solid rgba(255, 107, 53, 0.25);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .article-header h1 {
      font-size: 1.4rem;
    }

    .article-date {
      margin-left: 0;
    }

    .btn-source {
      margin-left: 0;
      width: 100%;
      text-align: center;
    }
  }
</style>
