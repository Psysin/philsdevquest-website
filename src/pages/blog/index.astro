---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagLabel: Record<string, string> = {
  python: "🐍 Python",
  godot: "🎮 Godot",
  allgemein: "💡 Allgemein",
  tools: "🛠 Tools",
};
---

<BaseLayout
  title="Blog"
  description="Gedanken, Erfahrungen und Tipps rund um Python, Godot und das Leben als Indie-Dev."
>
  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="blog-hero">
    <div class="blog-hero__inner">
      <p class="blog-hero__kicker">Notizen vom Lernweg</p>
      <h1 class="blog-hero__headline">Blog</h1>
      <p class="blog-hero__sub">
        Gedanken, Erfahrungen und Erkenntnisse aus dem Alltag als lernender
        Entwickler — ehrlich, praktisch, von Anfänger zu Anfänger.
      </p>
    </div>
  </section>

  <!-- ─── FILTER + GRID ─────────────────────────────────────── -->
  <section class="blog-main">
    <div class="blog-main__inner">
      <!-- Filter-Tabs -->
      <div class="blog-filter" role="tablist" aria-label="Tag filtern">
        <button
          class="blog-filter__btn active"
          data-filter="all"
          role="tab"
          aria-selected="true"
        >
          Alle <span class="blog-filter__count">{allPosts.length}</span>
        </button>
        {
          (["python", "godot", "allgemein", "tools"] as const).map((tag) => {
            const count = allPosts.filter((p) => p.data.tag === tag).length;
            return count > 0 ? (
              <button
                class="blog-filter__btn"
                data-filter={tag}
                role="tab"
                aria-selected="false"
              >
                <span class={`blog-filter__dot dot--${tag}`} />
                {tagLabel[tag].split(" ")[1]}
                <span class="blog-filter__count">{count}</span>
              </button>
            ) : null;
          })
        }
      </div>

      <!-- Kein Inhalt -->
      {
        allPosts.length === 0 && (
          <div class="blog-empty">
            <p>Noch keine Artikel vorhanden — bald geht's los! ✍️</p>
          </div>
        )
      }

      <!-- Blog-Grid -->
      <div class="blog-grid" id="blog-grid">
        {
          allPosts.map((post, i) => {
            const formattedDate = post.data.date.toLocaleDateString("de-DE", {
              day: "2-digit",
              month: "short",
              year: "numeric",
            });
            return (
              <a
                href={`/blog/${post.slug}`}
                class={`blog-card${i === 0 ? " blog-card--featured" : ""}`}
                data-tag={post.data.tag}
              >
                <div class="blog-card__top">
                  <span class={`badge badge--${post.data.tag}`}>
                    {tagLabel[post.data.tag]}
                  </span>
                  {i === 0 && <span class="badge badge--new">Neu</span>}
                </div>

                <h2 class="blog-card__title">{post.data.title}</h2>
                <p class="blog-card__desc">{post.data.description}</p>

                <div class="blog-card__footer">
                  <span class="blog-card__date">{formattedDate}</span>
                  <span class="blog-card__cta">Lesen →</span>
                </div>
              </a>
            );
          })
        }
      </div>

      <!-- No results (JS-gesteuert) -->
      <div class="blog-noresult" id="blog-noresult" style="display:none;">
        <p>Keine Artikel mit diesem Tag gefunden.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons =
    document.querySelectorAll<HTMLButtonElement>(".blog-filter__btn");
  const cards = document.querySelectorAll<HTMLElement>(".blog-card");
  const noResult = document.getElementById("blog-noresult")!;

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;

      buttons.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-selected", "true");

      let visible = 0;
      cards.forEach((card) => {
        const match = filter === "all" || card.dataset.tag === filter;
        card.style.display = match ? "" : "none";
        if (match) visible++;
      });

      noResult.style.display = visible === 0 ? "block" : "none";
    });
  });
</script>

<style>
  /* ── HERO ── */
  .blog-hero {
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    border-bottom: 1px solid var(--pdq-border-subtle);
  }
  .blog-hero__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .blog-hero__kicker {
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pdq-sand);
    margin-bottom: 0.75rem;
  }

  .blog-hero__headline {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    color: var(--pdq-text-primary);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .blog-hero__sub {
    font-family: var(--pdq-font-mono);
    font-size: 0.95rem;
    color: var(--pdq-text-secondary);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ── MAIN ── */
  .blog-main {
    padding: 3rem 1.5rem 5rem;
  }
  .blog-main__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── FILTER ── */
  .blog-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .blog-filter__btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--pdq-border-default);
    background: var(--pdq-bg-elevated);
    color: var(--pdq-text-secondary);
    font-family: var(--pdq-font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .blog-filter__btn:hover {
    border-color: var(--pdq-border-strong);
    color: var(--pdq-text-primary);
  }
  .blog-filter__btn.active {
    background: var(--pdq-sand);
    border-color: var(--pdq-sand);
    color: #1a1410;
  }

  .blog-filter__count {
    font-size: 0.72rem;
    opacity: 0.65;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 999px;
    padding: 0.05em 0.45em;
  }

  .blog-filter__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot--python {
    background: var(--pdq-terracotta);
  }
  .dot--godot {
    background: var(--pdq-sand);
  }
  .dot--allgemein {
    background: var(--pdq-cream);
  }
  .dot--tools {
    background: var(--pdq-orange);
  }

  /* ── GRID ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Featured-Karte: volle Breite */
  .blog-card--featured {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: flex-start;
    gap: 2rem;
  }

  @media (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .blog-card--featured {
      grid-column: 1 / -1;
      flex-direction: column;
    }
  }
  @media (max-width: 600px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── CARD ── */
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--pdq-border-default);
    background: var(--pdq-bg-elevated);
    text-decoration: none;
    transition:
      border-color 0.18s ease,
      transform 0.18s ease,
      background 0.18s ease;
  }
  .blog-card:hover {
    border-color: var(--pdq-sand);
    background: var(--pdq-bg-overlay);
    transform: translateY(-2px);
  }

  /* Featured spezifisch */
  .blog-card--featured {
    background: var(--pdq-bg-overlay);
    border-color: var(--pdq-border-default);
    padding: 2rem;
  }
  .blog-card--featured .blog-card__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }
  .blog-card--featured .blog-card__desc {
    font-size: 0.92rem;
    max-width: 65ch;
  }
  .blog-card--featured:hover {
    border-color: var(--pdq-sand);
  }

  .blog-card__top {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Badges */
  .badge {
    font-family: var(--pdq-font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.2em 0.65em;
    border-radius: 4px;
  }
  .badge--python {
    background: rgba(193, 99, 79, 0.15);
    color: var(--pdq-terracotta-light);
    border: 1px solid rgba(193, 99, 79, 0.3);
  }
  .badge--godot {
    background: rgba(212, 169, 106, 0.15);
    color: var(--pdq-sand-light);
    border: 1px solid rgba(212, 169, 106, 0.3);
  }
  .badge--allgemein {
    background: rgba(232, 201, 154, 0.12);
    color: var(--pdq-cream);
    border: 1px solid rgba(232, 201, 154, 0.25);
  }
  .badge--tools {
    background: rgba(255, 107, 53, 0.12);
    color: var(--pdq-orange);
    border: 1px solid rgba(255, 107, 53, 0.3);
  }
  .badge--new {
    background: rgba(255, 107, 53, 0.15);
    color: var(--pdq-orange);
    border: 1px solid rgba(255, 107, 53, 0.35);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.6;
    }
  }

  .blog-card__title {
    font-family: "Caveat", cursive;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--pdq-text-primary);
    line-height: 1.25;
    margin: 0;
  }

  .blog-card__desc {
    font-family: var(--pdq-font-mono);
    font-size: 0.85rem;
    color: var(--pdq-text-secondary);
    line-height: 1.65;
    flex: 1;
    margin: 0;
  }

  .blog-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid var(--pdq-border-subtle);
    margin-top: auto;
  }

  .blog-card__date {
    font-family: var(--pdq-font-mono);
    font-size: 0.78rem;
    color: var(--pdq-text-muted);
  }

  .blog-card__cta {
    font-family: var(--pdq-font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--pdq-orange);
  }
  .blog-card:hover .blog-card__cta {
    letter-spacing: 0.03em;
  }

  /* ── LEER / NO RESULT ── */
  .blog-empty,
  .blog-noresult {
    text-align: center;
    padding: 4rem 1rem;
    font-family: var(--pdq-font-mono);
    font-size: 0.9rem;
    color: var(--pdq-text-muted);
  }
</style>
