---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allBlog = await getCollection("blog", ({ data }) => !data.draft);
allBlog.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(date: Date) {
  const months = ["Jan","Feb","Mär","Apr","Mai","Jun","Jul","Aug","Sep","Okt","Nov","Dez"];
  return `${date.getDate()}. ${months[date.getMonth()]} ${date.getFullYear()}`;
}

const tagLabels: Record<string, string> = {
  python: "Python", godot: "Godot", allgemein: "Allgemein", tools: "Tools",
};
---

<BaseLayout
  title="Blog"
  description="Gedanken, Fehler, vielleicht kleine Durchbrüche. Ich schreibe über das, was mich gerade beschäftigt und was ich dabei gelernt habe."
>

<section class="blog-hero">
  <div class="container">
    <div class="section-eyebrow">Blog</div>
    <h1 class="section-title">Gedanken, Fehler, <span class="muted">vielleicht kleine Durchbrüche.</span></h1>
    <p class="section-sub">Ich schreibe über das, was mich gerade beschäftigt und was ich dabei gelernt habe.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="blog-list">
      {allBlog.map((post, i) => (
        <a href={`/blog/${post.slug}`} class="blog-item">
          <div class="blog-item-left">
            <span class="blog-item-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="blog-item-tag">{tagLabels[post.data.tag] ?? post.data.tag}</span>
          </div>
          <div class="blog-item-body">
            <h4>{post.data.title}</h4>
            <p>{post.data.description}</p>
          </div>
          <div class="blog-item-meta">
            <span>{formatDate(post.data.date)}</span>
            <span class="blog-item-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
  section { padding: 80px 0; }
  .blog-hero { padding-bottom: 0; }

  .section-eyebrow { font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pdq-terracotta); margin-bottom: 16px; }
  .section-title { font-weight: 600; font-size: clamp(28px, 4vw, 48px); line-height: 1.08; letter-spacing: -0.025em; color: var(--pdq-text-primary); max-width: 22ch; }
  .section-title .muted { color: var(--pdq-text-muted); }
  .section-sub { font-size: 18px; color: var(--pdq-text-secondary); line-height: 1.6; max-width: 560px; margin-top: 20px; }

  .blog-list { display: flex; flex-direction: column; }

  .blog-item {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 28px 0;
    border-bottom: 1px solid var(--pdq-border-subtle);
    text-decoration: none;
    color: inherit;
    transition: padding-left .2s;
  }
  .blog-item:first-child { border-top: 1px solid var(--pdq-border-subtle); }
  .blog-item:hover { padding-left: 8px; color: inherit; }

  .blog-item-left { display: flex; flex-direction: column; gap: 6px; flex-shrink: 0; }
  .blog-item-num { font-size: 11px; font-weight: 700; color: var(--pdq-text-disabled); letter-spacing: 0.06em; }
  .blog-item-tag { font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pdq-sand); }

  .blog-item-body { display: flex; flex-direction: column; gap: 6px; }
  .blog-item-body h4 { font-weight: 500; font-size: 18px; line-height: 1.3; color: var(--pdq-text-primary); letter-spacing: -0.01em; }
  .blog-item-body p { font-size: 13.5px; color: var(--pdq-text-muted); line-height: 1.6; }

  .blog-item-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; flex-shrink: 0; }
  .blog-item-meta span:first-child { font-size: 11.5px; color: var(--pdq-text-muted); white-space: nowrap; }
  .blog-item-arrow { font-size: 16px; color: var(--pdq-text-muted); transition: color .2s, transform .2s; display: inline-block; }
  .blog-item:hover .blog-item-arrow { color: var(--pdq-terracotta); transform: translateX(4px); }

  @media (max-width: 720px) {
    .container { padding: 0 20px; }
    .blog-item { grid-template-columns: 1fr; gap: 8px; }
    .blog-item-left { flex-direction: row; align-items: center; gap: 12px; }
    .blog-item-meta { flex-direction: row; align-items: center; }
  }
</style>
