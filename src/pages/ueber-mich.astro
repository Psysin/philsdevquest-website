---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Über mich" description="Die Person hinter PhilsDevQuest">
  <main
    style="max-width: 800px; margin: 0 auto; padding: 80px 24px; color: var(--pdq-text-primary);"
  >
    <h1
      style="font-family: 'JetBrains Mono', monospace; color: var(--pdq-terracotta);"
    >
      Über mich
    </h1>
    <p style="color: var(--pdq-text-secondary);">
      Von Anfänger zu Anfänger — kommt bald.
    </p>
  </main>
</BaseLayout>
