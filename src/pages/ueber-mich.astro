---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allBlog = await getCollection("blog", ({ data }) => !data.draft);
allBlog.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestBlog = allBlog.slice(0, 2);

const allDevlog = await getCollection("devlog", ({ data }) => !data.draft);
allDevlog.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestDevlog = allDevlog.slice(0, 2);

const tagLabels: Record<string, string> = {
  python: "Python", godot: "Godot", allgemein: "Allgemein", tools: "Tools",
};
---

<BaseLayout
  title="Über mich"
  description="Hi, ich bin Phil. Tagsüber Projektmanager, abends versuche ich zu verstehen wie das alles funktioniert. Das hier ist meine Reise."
>

  <!-- ─── HERO ─────────────────────────────────────────── -->
  <section class="about-hero">
    <div class="container">
      <div class="section-eyebrow">Wer ich bin</div>
      <h1 class="about-h1">Phil. <span class="muted">Jemand, der das gerade selbst durcharbeitet.</span></h1>
    </div>
  </section>

  <!-- ─── MAIN ─────────────────────────────────────────── -->
  <section class="about-main">
    <div class="container">
      <div class="about-grid">

        <div class="about-photo">
          <div class="about-photo-tag">Dev-Vibes, sag ich immer.</div>
        </div>

        <div class="about-body">
          <h2>Hi, ich bin Phil.</h2>
          <p>
            Tagsüber arbeite ich als <strong>Projektmanager</strong>. Abends sitze ich an meinem Schreibtisch,
            ein ThinkPad von eBay vor mir, und versuche zu verstehen wie das alles funktioniert.
          </p>
          <p>
            Ich hab schon ein paar Anläufe genommen, Python zu lernen. Kurse angefangen, Bücher gekauft,
            Tutorials angesehen. Und trotzdem blieb nicht viel hängen. Das Muster kenne ich von mir gut.
          </p>
          <p>
            Diesmal mache ich's anders: <strong>ich schreibe es auf</strong>. Was ich aktuell lerne,
            verarbeite ich in Devlogs und monatlichen Code Quizzes. Das zwingt mich, es wirklich zu verstehen.
          </p>
          <p>
            Das hier ist kein Lehrblog. Ich bin selbst mitten drin. Wenn du auch gerade anfängst
            oder schon länger dabei bist — lies mit, schreib mir, wir lernen zusammen.
          </p>

          <div class="about-topics">
            <div class="about-topic">
              <div class="topic-label">Python</div>
              <p class="topic-desc">
                Lesbar, strukturiert, riesiges Ökosystem. Und GDScript in Godot ist Python sehr ähnlich — einmal lernen, zweimal anwenden.
              </p>
            </div>
            <div class="about-topic about-topic--sand">
              <div class="topic-label">Godot</div>
              <p class="topic-desc">
                Open Source, nicht überladen. Für kleine Projekte stark genug — und niemand kann morgen die Lizenzbedingungen ändern.
              </p>
            </div>
            <div class="about-topic about-topic--orange">
              <div class="topic-label">KI als Werkzeug</div>
              <p class="topic-desc">
                Ich nutze KI täglich — als Gesprächspartner beim Durchdenken von Problemen, nicht als Abkürzung.
              </p>
            </div>
            <div class="about-topic about-topic--muted">
              <div class="topic-label">In der Öffentlichkeit lernen</div>
              <p class="topic-desc">
                Wenn ich aufschreibe was ich lerne und es teile, ist es schwerer aufzuhören. Die Öffentlichkeit hält mich ehrlicher als jede Disziplin.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── NEUESTE INHALTE ────────────────────────────────── -->
  {(latestBlog.length > 0 || latestDevlog.length > 0) && (
    <section class="about-recent-section">
      <div class="container">
        <div class="recent-cols">

          {latestBlog.length > 0 && (
            <div class="recent-col">
              <div class="section-eyebrow">Zuletzt im Blog</div>
              <div class="recent-list">
                {latestBlog.map((post) => (
                  <a href={`/blog/${post.slug}/`} class="recent-card">
                    <span class="recent-tag">{tagLabels[post.data.tag] ?? post.data.tag}</span>
                    <span class="recent-title">{post.data.title}</span>
                    <span class="recent-arrow">→</span>
                  </a>
                ))}
              </div>
              <a href="/blog/" class="recent-more">Alle Blog-Artikel →</a>
            </div>
          )}

          {latestDevlog.length > 0 && (
            <div class="recent-col">
              <div class="section-eyebrow">Zuletzt im Devlog</div>
              <div class="recent-list">
                {latestDevlog.map((entry) => (
                  <a href={`/devlog/${entry.slug}/`} class="recent-card">
                    <span class="recent-tag">{entry.data.project}{entry.data.episode !== undefined ? ` #${String(entry.data.episode).padStart(2,"0")}` : ""}</span>
                    <span class="recent-title">{entry.data.title}</span>
                    <span class="recent-arrow">→</span>
                  </a>
                ))}
              </div>
              <a href="/devlog/" class="recent-more">Alle Devlog-Einträge →</a>
            </div>
          )}

        </div>
      </div>
    </section>
  )}

  <!-- ─── SOCIAL ────────────────────────────────────────── -->
  <section class="about-social-section">
    <div class="container">
      <div class="section-eyebrow">Wo du mich findest</div>
      <div class="social-links">
        <a href="https://www.instagram.com/philsdevquest" target="_blank" rel="noopener" class="social-link">
          <span class="social-name">Instagram</span>
          <span class="social-handle">@philsdevquest</span>
        </a>
        <a href="https://www.tiktok.com/@philsdevquest" target="_blank" rel="noopener" class="social-link">
          <span class="social-name">TikTok</span>
          <span class="social-handle">@philsdevquest</span>
        </a>
        <a href="https://www.youtube.com/@philsdevquest" target="_blank" rel="noopener" class="social-link">
          <span class="social-name">YouTube</span>
          <span class="social-handle">@philsdevquest</span>
        </a>
        <a href="https://github.com/Psysin" target="_blank" rel="noopener" class="social-link">
          <span class="social-name">GitHub</span>
          <span class="social-handle">Psysin</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px;
  }

  section { padding: 80px 0; }

  .section-eyebrow {
    font-family: var(--pdq-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pdq-terracotta);
    margin-bottom: 16px;
  }

  /* ── Hero ── */
  .about-hero {
    padding: 80px 0 0;
    background: var(--pdq-bg-base);
  }
  .about-h1 {
    font-family: var(--pdq-font-mono);
    font-weight: 600;
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--pdq-text-primary);
    max-width: 22ch;
  }
  .about-h1 .muted { color: var(--pdq-text-muted); }

  /* ── Main grid ── */
  .about-main { background: var(--pdq-bg-elevated); }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .about-photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--pdq-bg-overlay);
    background-image: url('/images/photo-desk-01.png');
    background-size: cover;
    background-position: center;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(26,21,18,0.04), 0 12px 40px -12px rgba(26,21,18,0.18);
    position: sticky;
    top: 80px;
  }
  .about-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(0,0,0,0.45) 100%);
  }
  .about-photo-tag {
    position: absolute;
    bottom: 24px;
    left: 24px;
    z-index: 2;
    font-family: var(--pdq-font-hand);
    font-weight: 600;
    color: var(--pdq-cream);
    font-size: 22px;
    text-shadow: 0 1px 12px rgba(0,0,0,0.5);
  }

  .about-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .about-body h2 {
    font-family: var(--pdq-font-mono);
    font-weight: 600;
    font-size: 32px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--pdq-text-primary);
  }
  .about-body p {
    font-size: 16px;
    color: var(--pdq-text-secondary);
    line-height: 1.75;
  }
  .about-body p strong {
    color: var(--pdq-text-primary);
    font-weight: 500;
  }

  /* Topics */
  .about-topics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 12px;
    padding-top: 28px;
    border-top: 1px solid var(--pdq-border-default);
  }
  .about-topic {
    padding: 16px 18px;
    border-radius: 12px;
    border: 1px solid var(--pdq-border-default);
    border-left: 3px solid var(--pdq-terracotta);
    background: var(--pdq-bg-base);
  }
  .about-topic--sand { border-left-color: var(--pdq-sand); }
  .about-topic--orange { border-left-color: var(--pdq-orange); }
  .about-topic--muted { border-left-color: var(--pdq-text-muted); }

  .topic-label {
    font-family: var(--pdq-font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--pdq-text-primary);
    margin-bottom: 6px;
  }
  .topic-desc {
    font-family: var(--pdq-font-mono);
    font-size: 12.5px;
    color: var(--pdq-text-muted);
    line-height: 1.6;
  }

  /* ── Recent ── */
  .about-recent-section { background: var(--pdq-bg-base); }
  .recent-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .recent-col { display: flex; flex-direction: column; gap: 16px; }

  .recent-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--pdq-border-default);
    border-radius: 14px;
    overflow: hidden;
  }
  .recent-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: var(--pdq-bg-elevated);
    border-bottom: 1px solid var(--pdq-border-subtle);
    text-decoration: none;
    color: inherit;
    transition: background .15s;
  }
  .recent-card:last-child { border-bottom: none; }
  .recent-card:hover { background: var(--pdq-bg-overlay); }

  .recent-tag {
    font-size: 10.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pdq-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .recent-title {
    font-size: 14px;
    color: var(--pdq-text-primary);
    flex: 1;
    line-height: 1.4;
  }
  .recent-arrow {
    color: var(--pdq-text-muted);
    font-size: 13px;
    flex-shrink: 0;
    transition: color .15s, transform .15s;
  }
  .recent-card:hover .recent-arrow {
    color: var(--pdq-terracotta);
    transform: translateX(3px);
  }
  .recent-more {
    font-size: 13px;
    font-weight: 500;
    color: var(--pdq-terracotta);
    text-decoration: none;
    transition: color .2s;
  }
  .recent-more:hover { color: var(--pdq-text-primary); }

  /* ── Social ── */
  .about-social-section {
    background: var(--pdq-bg-elevated);
    padding: 64px 0 80px;
  }
  .social-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .social-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 18px 24px;
    border-radius: 14px;
    border: 1px solid var(--pdq-border-default);
    background: var(--pdq-bg-base);
    text-decoration: none;
    transition: border-color .2s, box-shadow .2s, transform .2s;
    min-width: 160px;
  }
  .social-link:hover {
    border-color: var(--pdq-terracotta);
    box-shadow: 0 4px 16px -4px rgba(184,85,64,0.12);
    transform: translateY(-2px);
    color: inherit;
  }
  .social-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--pdq-text-primary);
  }
  .social-handle {
    font-size: 12px;
    color: var(--pdq-text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-photo { position: static; aspect-ratio: 16 / 9; }
    .recent-cols { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 600px) {
    .container { padding: 0 20px; }
    .about-topics { grid-template-columns: 1fr; }
    section { padding: 56px 0; }
  }
</style>
