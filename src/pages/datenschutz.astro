---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Datenschutz"
  description="Datenschutzerklärung von PhilsDevQuest"
>
  <main
    style="max-width: 800px; margin: 0 auto; padding: 80px 24px; color: var(--pdq-text-primary);"
  >
    <h1
      style="font-family: 'JetBrains Mono', monospace; color: var(--pdq-terracotta);"
    >
      Datenschutz
    </h1>
    <p style="color: var(--pdq-text-secondary);">
      Datenschutzerklärung folgt vor dem Launch.
    </p>
  </main>
</BaseLayout>
