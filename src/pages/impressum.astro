---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Impressum" description="Impressum von PhilsDevQuest">
  <main
    style="max-width: 800px; margin: 0 auto; padding: 80px 24px; color: var(--pdq-text-primary);"
  >
    <h1
      style="font-family: 'JetBrains Mono', monospace; color: var(--pdq-terracotta);"
    >
      Impressum
    </h1>
    <p style="color: var(--pdq-text-secondary);">
      Pflichtangaben folgen vor dem Launch.
    </p>
  </main>
</BaseLayout>
