---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import NewsletterForm from "../components/NewsletterForm.astro";

// Blog: neueste 3
const allBlog = await getCollection("blog", ({ data }) => !data.draft);
allBlog.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const blogPosts = allBlog.slice(0, 3);

// Devlog: neueste 5
const allDevlog = await getCollection("devlog", ({ data }) => !data.draft);
allDevlog.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const devlogEntries = allDevlog.slice(0, 5);

function formatDate(date: Date) {
  const months = ["Jan","Feb","Mär","Apr","Mai","Jun","Jul","Aug","Sep","Okt","Nov","Dez"];
  return `${date.getDate()}. ${months[date.getMonth()]} ${date.getFullYear()}`;
}

function getBlogTagLabel(tag: string) {
  const map: Record<string, string> = {
    python: "Python", godot: "Godot", allgemein: "Allgemein", tools: "Tools",
  };
  return map[tag] || tag;
}
---

<BaseLayout
  title="PhilsDevQuest"
  description="Meine Reise vom Python-Anfänger zum Indie Dev. Devlogs, Blog und monatliche Code Quizzes von Phil."
>

<!-- ══════════ HERO ══════════ -->
<section class="hero">
  <div class="hero-glow-1"></div>
  <div class="hero-glow-2"></div>
  <div class="hero-inner">
    <span class="hero-tagline">Meine Reise vom Python-Anfänger zum Indie Dev</span>
    <h1>
      Hi, ich bin Phil.<br />
      Und ich lerne <span class="accent">gerade Python.</span>
    </h1>
    <p class="hero-lead">
      Was ich lerne, verarbeite ich hier in Devlogs, oder Quizzes auf meinen Socials sowie meinem monatlichen Newsletter.<br />
      Meine Gedanken teile ich außerdem in regelmäßigen Blog Artikeln.
    </p>
    <div class="hero-buttons">
      <a href="/devlog" class="btn btn-primary">Meine Reise mitlesen <span class="btn-arrow">→</span></a>
      <a href="/ueber-mich" class="btn btn-secondary">Wer ich bin</a>
    </div>
  </div>
</section>

<!-- ══════════ WORAN ICH GERADE SITZE ══════════ -->
<section class="band-elevated">
  <div class="container">
    <div class="section-head">
      <div class="section-eyebrow">Woran ich gerade sitze</div>
      <h2 class="section-title">Kein Plan, nur <span class="muted">ein nächster Schritt.</span></h2>
      <p class="section-sub">Ich arbeite mich Woche für Woche weiter. Hier steht, was gerade offen auf meinem Schreibtisch liegt.</p>
    </div>
    <div class="about-grid">
      <div class="about-photo">
        <div class="about-photo-tag">Dev-Vibes, sag ich immer.</div>
      </div>
      <div class="about-body">
        <h3>Gerade auf dem Schreibtisch</h3>
        <p><strong>Python:</strong> asyncio. Ich dachte, ich verstehe es. Dann ist ein Task einfach verschwunden und ich hab' zehn Minuten auf None gestarrt.</p>
        <p><strong>Godot:</strong> Projekt 1 — ein kleines 2D-Spiel. Gerade kämpfe ich mit TileMap-Kollisionen.</p>
        <p><strong>Nebenher:</strong> das Cheat-Sheet wächst mit. Jedes Mal, wenn ich etwas zum dritten Mal nachschlage, landet es dort.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════ BLOG PREVIEW ══════════ -->
<section>
  <div class="container">
    <div class="section-head section-head--flex">
      <div>
        <div class="section-eyebrow">Blog</div>
        <h2 class="section-title">Was mir unterwegs <span class="muted">durch den Kopf geht.</span></h2>
      </div>
      <a href="/blog" class="btn btn-secondary">Alles lesen <span class="btn-arrow">→</span></a>
    </div>
    <div class="card-grid">
      {blogPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="card">
          <span class="card-tag">{getBlogTagLabel(post.data.tag)}</span>
          <h4>{post.data.title}</h4>
          <p>{post.data.description}</p>
          <div class="card-meta">
            <span>{formatDate(post.data.date)}</span>
            <span class="card-read">Lesen →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══════════ DEVLOG PREVIEW ══════════ -->
<section class="band-elevated">
  <div class="container">
    <div class="section-head section-head--flex">
      <div>
        <div class="section-eyebrow">Devlog</div>
        <h2 class="section-title">Meine Reise, <span class="muted">Folge für Folge.</span></h2>
      </div>
      <a href="/devlog" class="btn btn-secondary">Zum Devlog <span class="btn-arrow">→</span></a>
    </div>

    {devlogEntries.length > 0 && (
      <div class="devlog-list">
        {devlogEntries.map((entry) => (
          <a href={`/devlog/${entry.slug}`} class={`devlog-row ${entry.data.project === 'Godot' ? 'devlog-row--godot' : ''}`}>
            <div class="devlog-num">
              <span class="track-dot"></span>
              {entry.data.project === 'Python Lernreise' ? 'Python' : 'Godot'}
            </div>
            <div class="devlog-tt">{entry.data.title}</div>
            <div class="devlog-date">{formatDate(entry.data.date)}</div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<!-- ══════════ NEWSLETTER ══════════ -->
<section class="band-elevated" id="newsletter">
  <div class="container">
    <NewsletterForm variant="section" />
  </div>
</section>

</BaseLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
  section { padding: 100px 0; position: relative; }
  section.band-elevated { background: var(--pdq-bg-elevated); }
  .section-head { margin-bottom: 56px; }
  .section-head--flex { display: flex; justify-content: space-between; align-items: flex-end; gap: 32px; flex-wrap: wrap; }
  .section-eyebrow { font-family: var(--pdq-font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pdq-terracotta); margin-bottom: 16px; }
  .section-title { font-family: var(--pdq-font-mono); font-weight: 600; font-size: clamp(28px, 4vw, 48px); line-height: 1.08; letter-spacing: -0.025em; color: var(--pdq-text-primary); max-width: 22ch; }
  .section-title .muted { color: var(--pdq-text-muted); }
  .section-sub { font-size: 18px; color: var(--pdq-text-secondary); line-height: 1.6; max-width: 560px; margin-top: 20px; }

  .hero { position: relative; overflow: hidden; padding: 120px 32px 140px; }
  .hero-inner { max-width: 980px; margin: 0 auto; position: relative; z-index: 1; }
  .hero-glow-1 { position: absolute; top: -20%; left: -10%; width: 60vw; height: 60vw; pointer-events: none; background: radial-gradient(circle, rgba(184,85,64,0.06) 0%, transparent 60%); }
  .hero-glow-2 { position: absolute; bottom: -30%; right: -10%; width: 50vw; height: 50vw; pointer-events: none; background: radial-gradient(circle, rgba(184,144,63,0.05) 0%, transparent 60%); }
  .hero-tagline { font-family: var(--pdq-font-hand); font-weight: 600; font-size: 28px; color: var(--pdq-text-muted); margin-bottom: 24px; display: block; }
  .hero h1 { font-family: var(--pdq-font-mono); font-weight: 600; font-size: clamp(22px, 3.5vw, 44px); line-height: 1.1; letter-spacing: -0.03em; color: var(--pdq-text-primary); margin-bottom: 28px; max-width: 20ch; }
  .hero h1 .accent { color: var(--pdq-terracotta); }
  .hero-lead { font-size: 18px; line-height: 1.65; color: var(--pdq-text-secondary); max-width: 620px; margin-bottom: 40px; letter-spacing: -0.005em; }
  .hero-buttons { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--pdq-font-mono); font-size: 14px; font-weight: 500; padding: 14px 28px; border-radius: 999px; transition: background .2s, color .2s, border-color .2s; cursor: pointer; text-decoration: none; }
  .btn-primary { background: var(--pdq-orange); color: #fff; }
  .btn-primary:hover { background: var(--pdq-orange-dark); color: #fff; }
  .btn-secondary { background: transparent; color: var(--pdq-text-primary); border: 1px solid var(--pdq-border-strong); }
  .btn-secondary:hover { border-color: var(--pdq-text-primary); background: rgba(26,21,18,0.03); color: var(--pdq-text-primary); }
  .btn-arrow { transition: transform .2s; }
  .btn:hover .btn-arrow { transform: translateX(3px); }

  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .about-photo { width: 100%; aspect-ratio: 4 / 5; background: var(--pdq-bg-overlay); background-image: url('/images/photo-desk-01.png'); background-size: cover; background-position: center; border-radius: 20px; position: relative; overflow: hidden; box-shadow: 0 1px 2px rgba(26,21,18,0.04), 0 12px 40px -12px rgba(26,21,18,0.18); }
  .about-photo::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 45%, rgba(0,0,0,0.45) 100%); }
  .about-photo-tag { position: absolute; bottom: 24px; left: 24px; z-index: 2; font-family: var(--pdq-font-hand); font-weight: 600; color: var(--pdq-cream); font-size: 22px; text-shadow: 0 1px 12px rgba(0,0,0,0.5); }
  .about-body { display: flex; flex-direction: column; gap: 20px; }
  .about-body h3 { font-family: var(--pdq-font-mono); font-weight: 600; font-size: 28px; line-height: 1.15; letter-spacing: -0.02em; color: var(--pdq-text-primary); }
  .about-body p { font-size: 16px; color: var(--pdq-text-secondary); line-height: 1.75; }
  .about-body p strong { color: var(--pdq-text-primary); font-weight: 500; }

  .card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .card { background: var(--pdq-bg-elevated); border-radius: 18px; padding: 28px 28px 30px; position: relative; transition: transform .25s ease, box-shadow .25s ease; cursor: pointer; display: flex; flex-direction: column; gap: 12px; min-height: 220px; box-shadow: 0 1px 2px rgba(26,21,18,0.04), 0 1px 0 rgba(26,21,18,0.03); text-decoration: none; color: inherit; }
  .card::before { content: ''; position: absolute; top: 0; left: 24px; right: 24px; height: 2px; background: linear-gradient(90deg, var(--pdq-terracotta), var(--pdq-sand)); border-radius: 0 0 2px 2px; opacity: 0.9; }
  .card:hover { transform: translateY(-3px); box-shadow: 0 2px 4px rgba(26,21,18,0.06), 0 16px 40px -12px rgba(26,21,18,0.14); color: inherit; }
  .card-tag { font-family: var(--pdq-font-mono); font-size: 10.5px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pdq-sand); }
  .card h4 { font-family: var(--pdq-font-mono); font-weight: 500; font-size: 18px; line-height: 1.35; color: var(--pdq-text-primary); letter-spacing: -0.01em; }
  .card p { font-size: 14px; color: var(--pdq-text-secondary); line-height: 1.65; flex: 1; }
  .card-meta { display: flex; justify-content: space-between; align-items: center; font-size: 11.5px; color: var(--pdq-text-muted); padding-top: 6px; }
  .card-read { color: var(--pdq-text-secondary); transition: color .2s; }
  .card:hover .card-read { color: var(--pdq-terracotta); }

  .devlog-list { display: flex; flex-direction: column; gap: 2px; }
  .devlog-row { display: grid; grid-template-columns: 120px 1fr auto; gap: 24px; align-items: center; padding: 20px 0; border-bottom: 1px solid var(--pdq-border-subtle); cursor: pointer; transition: padding .2s; text-decoration: none; color: inherit; }
  .devlog-row:hover { padding-left: 8px; color: inherit; }
  .devlog-num { font-family: var(--pdq-font-mono); font-size: 12px; color: var(--pdq-text-muted); letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px; }
  .track-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--pdq-terracotta); flex-shrink: 0; }
  .devlog-row--godot .track-dot { background: var(--pdq-sand); }
  .devlog-tt { font-family: var(--pdq-font-mono); font-weight: 500; font-size: 15px; color: var(--pdq-text-primary); letter-spacing: -0.005em; }
  .devlog-date { font-family: var(--pdq-font-mono); font-size: 12px; color: var(--pdq-text-muted); white-space: nowrap; }

  @media (max-width: 960px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 860px) { .about-grid { grid-template-columns: 1fr; gap: 40px; } }
  @media (max-width: 720px) { .hero { padding: 80px 24px 100px; } section { padding: 72px 0; } .container { padding: 0 20px; } .card-grid { grid-template-columns: 1fr; } .devlog-row { grid-template-columns: 1fr; gap: 6px; } .devlog-date { display: none; } }
  @media (max-width: 640px) { .section-head--flex { flex-direction: column; align-items: flex-start; } }
</style>
