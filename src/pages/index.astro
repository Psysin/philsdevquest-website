      color: var(--pdq-text-disabled);
    }
    .t-keyword {
      color: var(--pdq-sand);
    }
    .t-builtin {
      color: var(--pdq-terracotta-light);
    }
    .t-string {
      color: #a8c5a0;
    }
    .t-number {
      color: var(--pdq-cream);
    }
    .t-plain {
