    /* ── NEWSTICKER ── */
    .ticker-wrap {
      background: var(--pdq-bg-elevated);
      border-top: 1px solid var(--pdq-border-subtle);
      border-bottom: 1px solid var(--pdq-border-subtle);
      overflow: hidden;
      position: relative;
    }
    .ticker-label {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      z-index: 10;
      display: flex;
      align-items: center;
      padding: 0 20px;
      background: var(--pdq-terracotta);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.5px;
      color: #12100e;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .ticker-label::after {
      content: "";
      position: absolute;
      right: -12px;
      top: 0;
      bottom: 0;
      width: 12px;
      background: linear-gradient(to right, var(--pdq-terracotta), transparent);
    }
    .ticker-fade-right {
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 80px;
