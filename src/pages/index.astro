    }
    .blog-tag.python-t {
      color: var(--pdq-terracotta);
    }
    .blog-tag.allgemein {
      color: var(--pdq-cream);
    }
    .blog-tag.tools {
      color: var(--pdq-sand);
    }
    .blog-tag.godot {
      color: var(--pdq-sand);
    }
    .blog-title {
