      color: var(--pdq-text-muted);
      line-height: 1.6;
    }
    .tool-tag {
      display: inline-block;
      margin-top: 10px;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
