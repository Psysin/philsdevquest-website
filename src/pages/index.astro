---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import NewsletterForm from "../components/NewsletterForm.astro";

// Tutorials: nur nicht-draft, neueste zuerst, max. 3
const allTutorials = await getCollection(
  "tutorials",
  ({ data }) => !data.draft,
);
allTutorials.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const tutorials = allTutorials.slice(0, 3);

// Blog: nur nicht-draft, neueste zuerst, max. 5
const allBlog = await getCollection("blog", ({ data }) => !data.draft);
allBlog.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const blogPosts = allBlog.slice(0, 5);

// News: neueste zuerst, alle
const allNews = await getCollection("news");
allNews.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const newsItems = allNews.slice(0, 5); // ← nur die 5 neuesten

// Helper-Funktionen
function getCatClass(category: string) {
  return category === "python" ? "py" : "gd";
}
function getCatLabel(category: string) {
  return category === "python" ? "🐍 Python" : "🎮 Godot";
}
function getThumbClass(category: string) {
  return category === "python" ? "python-bg" : "godot-bg";
}
function getGlowClass(category: string) {
  return category === "python" ? "tg-python" : "tg-godot";
}
function getDiffClass(difficulty: string) {
  if (difficulty === "einsteiger") return "diff-beginner";
  if (difficulty === "grundlagen") return "diff-basics";
  return "diff-beginner";
}
function getDiffLabel(difficulty: string) {
  const map: Record<string, string> = {
    einsteiger: "Einsteiger",
    grundlagen: "Grundlagen",
    fortgeschritten: "Fortgeschritten",
  };
  return map[difficulty] || difficulty;
}
function getNewsBadge(category: string) {
  const map: Record<string, string> = {
    Python: "py",
    Godot: "gd",
    Coding: "co",
  };
  return map[category] || "co";
}
function getBlogTagClass(tag: string) {
  return tag === "python" ? "python-t" : tag;
}
function getBlogTagLabel(tag: string) {
  const map: Record<string, string> = {
    python: "Python",
    godot: "Godot",
    allgemein: "Allgemein",
    tools: "Tools",
  };
  return map[tag] || tag;
}
function formatDay(date: Date) {
  return date.getDate().toString().padStart(2, "0");
}
function formatMonth(date: Date) {
  const months = [
    "Jan",
    "Feb",
    "Mär",
    "Apr",
    "Mai",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Okt",
    "Nov",
    "Dez",
  ];
  return `${months[date.getMonth()]} ${date.getFullYear()}`;
}

// Tools bleiben vorerst statisch (Phase 2 — eigene Collection kommt)
const tools = [
  {
    icon: "🎮",
    name: "Godot Engine",
    desc: "Open Source Game Engine — ideal für Einsteiger und Indie Devs",
    tag: "free",
    tagLabel: "Kostenlos",
  },
  {
    icon: "🐍",
    name: "Python",
    desc: "Die beste erste Programmiersprache — übersichtlich, mächtig, überall einsetzbar",
    tag: "free",
    tagLabel: "Kostenlos",
  },
  {
    icon: "⚡",
    name: "n8n",
    desc: "Self-hosted Automatisierungsplattform — mein Content-Rückgrat",
    tag: "free",
    tagLabel: "Open Source",
  },
  {
    icon: "💻",
    name: "VS Code",
    desc: "Der Editor für alles — mit den richtigen Extensions unschlagbar",
    tag: "free",
    tagLabel: "Kostenlos",
  },
];
---

<BaseLayout title="Start">
  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="fade-up-1">
          <div class="hero-eyebrow">
            Python & Godot für Indie Game Devs und Anfänger
          </div>
          <h1 class="hero-headline">
            Python & Godot<br />
            lernen —<br />
            <em>ohne Fachchinesisch</em>
          </h1>
          <p class="hero-sub">
            Tutorials, Tipps und Einblicke rund um Python, Godot und Indie Game
            Dev. Monatlich — direkt, verständlich, praktisch.
          </p>
          <NewsletterForm variant="hero" />
        </div>

        <div class="fade-up-2 hero-visual-wrap">
          <div class="hero-badge-float">
            <span class="hero-badge-dot"></span>
            <span>Neues Tutorial verfügbar</span>
          </div>
          <div class="terminal">
            <div class="terminal-bar">
              <span class="terminal-dot red"></span>
              <span class="terminal-dot yellow"></span>
              <span class="terminal-dot green"></span>
              <span class="terminal-title">main.py — PhilsDevQuest</span>
            </div>
            <div class="terminal-body">
              <div><span class="t-comment"># Wer bin ich?</span></div>
              <div>
                <span class="t-keyword">class </span><span class="t-plain"
                  >PhilsDevQuest:</span
                >
              </div>
              <div>
                &nbsp;&nbsp;<span class="t-builtin">def </span><span
                  class="t-plain">__init__(self):</span
                >
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain"
                  >self.focus = [</span
                >
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-string"
                  >"Python"</span
                ><span class="t-plain">,</span>
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-string"
                  >"Godot"</span
                ><span class="t-plain">,</span>
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-string"
                  >"Indie Game Dev"</span
                >
              </div>
              <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain">]</span></div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain"
                  >self.level =
                </span><span class="t-string">"Anfänger"</span>
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain"
                  >self.newsletter =
                </span><span class="t-number">True</span>
              </div>
              <div>
                &nbsp;&nbsp;<span class="t-builtin">def </span><span
                  class="t-plain">mitmachen(self):</span
                >
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-orange">print</span><span
                  class="t-plain">(</span
                ><span class="t-string">"Let's go! 🚀"</span><span
                  class="t-plain">)</span
                >
              </div>
              <div style="margin-top:8px">
                <span class="t-plain">pdq = PhilsDevQuest()</span>
              </div>
              <div>
                <span class="t-plain">pdq.mitmachen()</span>&nbsp;<span
                  class="cursor"></span>
              </div>
            </div>
            <div class="terminal-tags">
              <span class="t-tag python">🐍 Python</span>
              <span class="t-tag godot">🎮 Godot</span>
              <span class="t-tag n8n">⚡ n8n</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ NEWSTICKER ══════════ -->
  <div class="ticker-wrap">
    <div class="ticker-label">News</div>
    <div class="ticker-fade-right"></div>
    <div class="ticker-track">
      {
        [...newsItems, ...newsItems].map((item) => (
          <>
            <a href={`/news/${item.slug}`} class="ticker-item">
              <span class={`ticker-badge ${getNewsBadge(item.data.category)}`}>
                {item.data.category}
              </span>
              <span class="ticker-text">{item.data.summary}</span>
              <span class="ticker-link">→ Artikel lesen</span>
            </a>
            <span class="ticker-sep">·</span>
          </>
        ))
      }
    </div>
  </div>

  <!-- ══════════ TUTORIALS ══════════ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="section-label">Tutorials</div>
          <h2 class="section-title-display">Schritt für Schritt lernen</h2>
        </div>
        <a href="/tutorials" class="section-link">Alle Tutorials →</a>
      </div>
      <div class="tutorials-grid">
        <!-- Featured (erstes Tutorial) -->
        {
          tutorials[0] && (
            <a
              href={`/tutorials/${tutorials[0].slug}`}
              class="tutorial-card featured"
            >
              <div
                class={`tutorial-thumb ${getThumbClass(tutorials[0].data.category)}`}
              >
                <div
                  class={`tutorial-glow ${getGlowClass(tutorials[0].data.category)}`}
                />
                {tutorials[0].data.category === "python" ? (
                  <div class="tutorial-thumb-code">
                    <div>
                      <span class="tc-kw">def</span>{" "}
                      <span class="tc-plain">berechne_summe(zahlen):</span>
                    </div>
                    <div>
                      &nbsp;&nbsp;
                      <span class="tc-comment"># Liste durchlaufen</span>
                    </div>
                    <div>
                      &nbsp;&nbsp;<span class="tc-kw">summe</span>{" "}
                      <span class="tc-plain">= 0</span>
                    </div>
                    <div>
                      &nbsp;&nbsp;<span class="tc-kw">for</span>{" "}
                      <span class="tc-plain">z in zahlen:</span>
                    </div>
                    <div>
                      &nbsp;&nbsp;&nbsp;&nbsp;
                      <span class="tc-plain">summe += z</span>
                    </div>
                    <div>
                      &nbsp;&nbsp;<span class="tc-kw">return</span>{" "}
                      <span class="tc-plain">summe</span>
                    </div>
                  </div>
                ) : (
                  <div class="tutorial-thumb-icon">🎮</div>
                )}
                <span
                  class={`tutorial-diff ${getDiffClass(tutorials[0].data.difficulty)}`}
                >
                  {getDiffLabel(tutorials[0].data.difficulty)}
                </span>
              </div>
              <div class="tutorial-body">
                <div
                  class={`tutorial-cat ${getCatClass(tutorials[0].data.category)}`}
                >
                  {getCatLabel(tutorials[0].data.category)}
                </div>
                <h3 class="tutorial-title">{tutorials[0].data.title}</h3>
                <p class="tutorial-desc">{tutorials[0].data.description}</p>
                <div class="tutorial-footer">
                  <div class="tutorial-meta">
                    📖 {tutorials[0].data.readTime} lesen
                  </div>
                  <span class="tutorial-arrow">→</span>
                </div>
              </div>
            </a>
          )
        }

        <!-- Small card 1 (zweites Tutorial) -->
        {
          tutorials[1] && (
            <a href={`/tutorials/${tutorials[1].slug}`} class="tutorial-card">
              <div
                class={`tutorial-thumb ${getThumbClass(tutorials[1].data.category)}`}
              >
                <div
                  class={`tutorial-glow ${getGlowClass(tutorials[1].data.category)}`}
                />
                <div class="tutorial-thumb-icon">
                  {tutorials[1].data.category === "python" ? "🐍" : "🎮"}
                </div>
                <span
                  class={`tutorial-diff ${getDiffClass(tutorials[1].data.difficulty)}`}
                >
                  {getDiffLabel(tutorials[1].data.difficulty)}
                </span>
              </div>
              <div class="tutorial-body">
                <div
                  class={`tutorial-cat ${getCatClass(tutorials[1].data.category)}`}
                >
                  {getCatLabel(tutorials[1].data.category)}
                </div>
                <h3 class="tutorial-title">{tutorials[1].data.title}</h3>
                <p class="tutorial-desc">{tutorials[1].data.description}</p>
                <div class="tutorial-footer">
                  <div class="tutorial-meta">
                    📖 {tutorials[1].data.readTime}
                  </div>
                  <span class="tutorial-arrow">→</span>
                </div>
              </div>
            </a>
          )
        }

        <!-- Small card 2 (drittes Tutorial) -->
        {
          tutorials[2] && (
            <a
              href={`/tutorials/${tutorials[2].slug}`}
              class="tutorial-card"
              style="grid-column:1"
            >
              <div
                class={`tutorial-thumb ${getThumbClass(tutorials[2].data.category)}`}
              >
                <div
                  class={`tutorial-glow ${getGlowClass(tutorials[2].data.category)}`}
                />
                <div class="tutorial-thumb-icon">
                  {tutorials[2].data.category === "python" ? "🐍" : "🎮"}
                </div>
                <span
                  class={`tutorial-diff ${getDiffClass(tutorials[2].data.difficulty)}`}
                >
                  {getDiffLabel(tutorials[2].data.difficulty)}
                </span>
              </div>
              <div class="tutorial-body">
                <div
                  class={`tutorial-cat ${getCatClass(tutorials[2].data.category)}`}
                >
                  {getCatLabel(tutorials[2].data.category)}
                </div>
                <h3 class="tutorial-title">{tutorials[2].data.title}</h3>
                <p class="tutorial-desc">{tutorials[2].data.description}</p>
                <div class="tutorial-footer">
                  <div class="tutorial-meta">
                    📖 {tutorials[2].data.readTime}
                  </div>
                  <span class="tutorial-arrow">→</span>
                </div>
              </div>
            </a>
          )
        }
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ══════════ NEWSLETTER ══════════ -->
  <section class="newsletter-section" id="newsletter">
    <div class="container">
      <div class="newsletter-box">
        <div class="newsletter-text">
          <div class="newsletter-kicker">✉️ PhilsDevQuest Monthly</div>
          <h2 class="newsletter-headline">
            Einmal pro Monat<br />
            <em>das Wichtigste</em><br />
            direkt ins Postfach
          </h2>
          <ul class="newsletter-bullets">
            <li>Python- & Godot-Tipp des Monats</li>
            <li>Neue Tutorials direkt zum Lesen</li>
            <li>Kurze News aus der Dev-Welt</li>
            <li>Mein persönlicher DevLog-Fortschritt</li>
          </ul>
          <div class="newsletter-social-proof">
            <div class="newsletter-avatars">
              <div class="avatar">👾</div>
              <div class="avatar">🐍</div>
              <div class="avatar">🎮</div>
              <div class="avatar">⚡</div>
            </div>
            <span class="newsletter-social-text">
              Schon <strong>einige Devs</strong> dabei — wirst du der nächste?
            </span>
          </div>
        </div>
        <NewsletterForm variant="hero" />
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ══════════ BLOG ══════════ -->
  <section class="section" style="padding-top:80px">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="section-label">Blog</div>
          <h2 class="section-title-display">
            Gedanken, Erfahrungen & Einblicke
          </h2>
        </div>
        <a href="/blog" class="section-link">Alle Artikel →</a>
      </div>
      <div class="blog-list">
        {
          blogPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-item">
              <div class="blog-date">
                <span class="blog-date-day">{formatDay(post.data.date)}</span>
                {formatMonth(post.data.date)}
              </div>
              <div class="blog-content">
                <div class={`blog-tag ${getBlogTagClass(post.data.tag)}`}>
                  {getBlogTagLabel(post.data.tag)}
                </div>
                <div class="blog-title">{post.data.title}</div>
                <div class="blog-excerpt">{post.data.description}</div>
              </div>
              <div class="blog-arrow">→</div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ══════════ TOOLS ══════════ -->
  <section class="section" style="padding-top:80px;padding-bottom:96px">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="section-label">Tools & Ressourcen</div>
          <h2 class="section-title-display">Was ich täglich nutze</h2>
        </div>
        <a href="/tools" class="section-link">Alle Tools →</a>
      </div>
      <div class="tools-grid">
        {
          tools.map((tool) => (
            <div class="tool-card">
              <div class="tool-icon">{tool.icon}</div>
              <div class="tool-name">{tool.name}</div>
              <div class="tool-desc">{tool.desc}</div>
              <span class={`tool-tag ${tool.tag}`}>{tool.tagLabel}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <style>
    /* ── Layout ── */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 32px;
    }
    .section {
      padding: 96px 0;
    }
    .section-divider {
      height: 1px;
      background: var(--pdq-border-subtle);
      margin: 0;
    }

    /* ── Section labels ── */
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--pdq-text-muted);
      margin-bottom: 12px;
    }
    .section-label::before {
      content: "";
      display: block;
      width: 20px;
      height: 1px;
      background: var(--pdq-text-disabled);
    }
    .section-title-display {
      font-family: "Fraunces", serif;
      font-size: 32px;
      font-weight: 300;
      letter-spacing: -0.5px;
      color: var(--pdq-text-primary);
    }
    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 40px;
    }
    .section-link {
      font-size: 11px;
      color: var(--pdq-text-muted);
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border: 1px solid var(--pdq-border-subtle);
      border-radius: 6px;
      transition: all 0.2s;
      text-decoration: none;
    }
    .section-link:hover {
      color: var(--pdq-cream);
      border-color: var(--pdq-border-default);
    }

    /* ── Animations ── */
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes ticker {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }
    @keyframes pulse-glow {
      0%,
      100% {
        opacity: 0.4;
      }
      50% {
        opacity: 0.9;
      }
    }
    @keyframes blink {
      0%,
      100% {
        opacity: 1;
      }
      50% {
        opacity: 0;
      }
    }
    .fade-up-1 {
      animation: fadeUp 0.7s 0.1s ease both;
    }
    .fade-up-2 {
      animation: fadeUp 0.7s 0.25s ease both;
    }

    /* ── HERO ── */
    .hero {
      padding: 100px 0 80px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: "";
      position: absolute;
      top: -100px;
      left: -200px;
      width: 600px;
      height: 600px;
      background: radial-gradient(
        ellipse,
        rgba(193, 99, 79, 0.07) 0%,
        transparent 70%
      );
      pointer-events: none;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(193, 99, 79, 0.14);
      border: 1px solid rgba(193, 99, 79, 0.2);
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      color: var(--pdq-terracotta-light);
      letter-spacing: 0.5px;
      margin-bottom: 28px;
    }
    .hero-eyebrow::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--pdq-terracotta);
      animation: pulse-glow 2s ease infinite;
    }
    .hero-headline {
      font-family: "Fraunces", serif;
      font-size: clamp(38px, 5vw, 54px);
      font-weight: 300;
      line-height: 1.1;
      color: var(--pdq-text-primary);
      letter-spacing: -1px;
      margin-bottom: 24px;
    }
    .hero-headline em {
      font-style: italic;
      color: var(--pdq-terracotta);
    }
    .hero-sub {
      font-size: 13px;
      color: var(--pdq-text-secondary);
      line-height: 1.8;
      margin-bottom: 36px;
      max-width: 420px;
    }
    .hero-form {
      display: flex;
      gap: 8px;
      max-width: 420px;
    }
    .hero-form input {
      flex: 1;
      background: var(--pdq-bg-elevated);
      border: 1px solid var(--pdq-border-default);
      border-radius: 6px;
      padding: 11px 16px;
      font-family: var(--pdq-font-mono);
      font-size: 12px;
      color: var(--pdq-text-primary);
      outline: none;
      transition: border-color 0.2s;
    }
    .hero-form input::placeholder {
      color: var(--pdq-text-disabled);
    }
    .hero-form input:focus {
      border-color: var(--pdq-terracotta);
    }
    .hero-form button {
      background: var(--pdq-orange);
      color: #12100e;
      border: none;
      border-radius: 6px;
      padding: 11px 20px;
      font-family: var(--pdq-font-mono);
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .hero-form button:hover {
      background: var(--pdq-orange-dark);
    }
    .hero-form-note {
      font-size: 10px;
      color: var(--pdq-text-disabled);
      margin-top: 10px;
    }

    /* Terminal */
    .hero-visual-wrap {
      position: relative;
    }
    .hero-badge-float {
      position: absolute;
      top: -16px;
      right: -16px;
      background: var(--pdq-bg-elevated);
      border: 1px solid var(--pdq-border-default);
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 11px;
      color: var(--pdq-text-secondary);
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      z-index: 2;
    }
    .hero-badge-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #28c840;
