---
import BaseLayout from "../layouts/BaseLayout.astro";

const tutorials = [
  {
    type: "featured",
    cat: "py",
    catLabel: "🐍 Python",
    title: "Python für Anfänger: Schleifen, Listen & Funktionen verstehen",
    desc: "Du lernst wie for-Schleifen wirklich funktionieren, was Listen sind und warum Funktionen dein Code-Leben leichter machen. Mit echten Beispielen aus dem Alltag.",
    url: "/tutorials/schleifen-listen-funktionen",
    diff: "Einsteiger",
    diffClass: "diff-beginner",
    thumbClass: "python-bg",
    meta: "📖 8 min lesen · Screenshots enthalten",
    showCode: true,
  },
  {
    type: "small",
    cat: "gd",
    catLabel: "🎮 Godot",
    title: "Dein erstes Godot-Projekt: Scene Tree erklärt",
    desc: "Was ist ein Node? Was ist eine Scene? Und warum ist der Scene Tree so wichtig? Erklärt ohne Vorkenntnisse.",
    url: "/tutorials/godot-scene-tree",
    diff: "Grundlagen",
    diffClass: "diff-basics",
    thumbClass: "godot-bg",
    icon: "🎮",
    meta: "📖 6 min",
  },
  {
    type: "small",
    cat: "py",
    catLabel: "🐍 Python",
    title: "Dictionaries in Python: Was, warum, wie",
    desc: "Der unterschätzte Datentyp. Lerne wann du ein Dictionary statt einer Liste nutzen solltest.",
    url: "/tutorials/python-dictionaries",
    diff: "Einsteiger",
    diffClass: "diff-beginner",
    thumbClass: "python-bg",
    icon: "🐍",
    meta: "📖 5 min",
  },
];

const newsItems = [
  {
    badge: "py",
    badgeLabel: "Python",
    text: "Python 3.15 Alpha 6: JIT-Compiler mit bis zu 8% Performance-Gewinn und UTF-8 als neuer Standard",
    url: "#",
  },
  {
    badge: "gd",
    badgeLabel: "Godot",
    text: "Godot 4.6.1 erschienen: 38 Bugfixes von 25 Contributors — was sich geändert hat",
    url: "#",
  },
  {
    badge: "co",
    badgeLabel: "Coding",
    text: "GitHub führt neue Code-Review-Features ein — Pull Requests werden schneller und übersichtlicher",
    url: "#",
  },
  {
    badge: "py",
    badgeLabel: "Python",
    text: "uv 0.6 released: Der schnellste Python Package Manager bekommt Workspaces-Unterstützung",
    url: "#",
  },
  {
    badge: "gd",
    badgeLabel: "Godot",
    text: "GodotCon 2026 angekündigt: Community-Event für alle Indie Game Devs diesen Sommer",
    url: "#",
  },
];

const blogPosts = [
  {
    day: "18",
    month: "Feb 2026",
    tag: "allgemein",
    tagLabel: "Allgemein",
    title: "Warum ich als kompletter Anfänger mit Godot angefangen habe",
    excerpt:
      "Kein Game Dev Hintergrund, keine Erfahrung — trotzdem. Was mich überzeugt hat und was ich nach den ersten Wochen gelernt habe.",
    url: "/blog/warum-godot",
  },
  {
    day: "12",
    month: "Feb 2026",
    tag: "python-t",
    tagLabel: "Python",
    title: "Meine ersten 30 Tage mit Python: Was ich anders machen würde",
    excerpt:
      "Rückblick auf den Start meiner Python-Journey. Die Fehler, die ich gemacht habe — damit du sie nicht machen musst.",
    url: "/blog/30-tage-python",
  },
  {
    day: "05",
    month: "Feb 2026",
    tag: "allgemein",
    tagLabel: "Tools",
    title:
      "n8n als Content-Maschine: Wie ich meinen Blog fast komplett automatisiert habe",
    excerpt:
      "Ein ehrlicher Einblick in meinen Automatisierungs-Stack — was funktioniert, was nicht, und was mich überrascht hat.",
    url: "/blog/n8n-content-maschine",
  },
];

const tools = [
  {
    icon: "🎮",
    name: "Godot Engine",
    desc: "Open Source Game Engine — ideal für Einsteiger und Indie Devs",
    tag: "free",
    tagLabel: "Kostenlos",
  },
  {
    icon: "🐍",
    name: "Python",
    desc: "Die beste erste Programmiersprache — übersichtlich, mächtig, überall einsetzbar",
    tag: "free",
    tagLabel: "Kostenlos",
  },
  {
    icon: "⚡",
    name: "n8n",
    desc: "Self-hosted Automatisierungsplattform — mein Content-Rückgrat",
    tag: "free",
    tagLabel: "Open Source",
  },
  {
    icon: "💻",
    name: "VS Code",
    desc: "Der Editor für alles — mit den richtigen Extensions unschlagbar",
    tag: "free",
    tagLabel: "Kostenlos",
  },
];
---

<BaseLayout title="Start">
  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="fade-up-1">
          <div class="hero-eyebrow">Von Anfänger zu Anfänger</div>
          <h1 class="hero-headline">
            Python & Godot<br />
            lernen —<br />
            <em>ohne Fachchinesisch</em>
          </h1>
          <p class="hero-sub">
            Tutorials, Tipps und Einblicke rund um Python, Godot und Indie Game
            Dev. Monatlich — direkt, verständlich, praktisch.
          </p>
          <form class="hero-form" action="#newsletter">
            <input type="email" placeholder="deine@email.de" />
            <button type="submit">Dabei sein →</button>
          </form>
          <p class="hero-form-note">
            Einmal pro Monat · Kein Spam · Jederzeit abmeldbar
          </p>
        </div>

        <div class="fade-up-2 hero-visual-wrap">
          <div class="hero-badge-float">
            <span class="hero-badge-dot"></span>
            <span>Neues Tutorial verfügbar</span>
          </div>
          <div class="terminal">
            <div class="terminal-bar">
              <span class="terminal-dot red"></span>
              <span class="terminal-dot yellow"></span>
              <span class="terminal-dot green"></span>
              <span class="terminal-title">main.py — PhilsDevQuest</span>
            </div>
            <div class="terminal-body">
              <div><span class="t-comment"># Wer bin ich?</span></div>
              <div>
                <span class="t-keyword">class </span><span class="t-plain"
                  >PhilsDevQuest:</span
                >
              </div>
              <div>
                &nbsp;&nbsp;<span class="t-builtin">def </span><span
                  class="t-plain">__init__(self):</span
                >
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain"
                  >self.focus = [</span
                >
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-string"
                  >"Python"</span
                ><span class="t-plain">,</span>
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-string"
                  >"Godot"</span
                ><span class="t-plain">,</span>
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-string"
                  >"Indie Game Dev"</span
                >
              </div>
              <div>&nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain">]</span></div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain"
                  >self.level =
                </span><span class="t-string">"Anfänger"</span>
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-plain"
                  >self.newsletter =
                </span><span class="t-number">True</span>
              </div>
              <div>
                &nbsp;&nbsp;<span class="t-builtin">def </span><span
                  class="t-plain">mitmachen(self):</span
                >
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="t-orange">print</span><span
                  class="t-plain">(</span
                ><span class="t-string">"Let's go! 🚀"</span><span
                  class="t-plain">)</span
                >
              </div>
              <div style="margin-top:8px">
                <span class="t-plain">pdq = PhilsDevQuest()</span>
              </div>
              <div>
                <span class="t-plain">pdq.mitmachen()</span>&nbsp;<span
                  class="cursor"></span>
              </div>
            </div>
            <div class="terminal-tags">
              <span class="t-tag python">🐍 Python</span>
              <span class="t-tag godot">🎮 Godot</span>
              <span class="t-tag n8n">⚡ n8n</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ NEWSTICKER ══════════ -->
  <div class="ticker-wrap">
    <div class="ticker-label">News</div>
    <div class="ticker-fade-right"></div>
    <div class="ticker-track">
      {
        [...newsItems, ...newsItems].map((item) => (
          <>
            <a href={item.url} class="ticker-item">
              <span class={`ticker-badge ${item.badge}`}>
                {item.badgeLabel}
              </span>
              <span class="ticker-text">{item.text}</span>
              <span class="ticker-link">→ Artikel lesen</span>
            </a>
            <span class="ticker-sep">·</span>
          </>
        ))
      }
    </div>
  </div>

  <!-- ══════════ TUTORIALS ══════════ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="section-label">Tutorials</div>
          <h2 class="section-title-display">Schritt für Schritt lernen</h2>
        </div>
        <a href="/tutorials" class="section-link">Alle Tutorials →</a>
      </div>
      <div class="tutorials-grid">
        <!-- Featured -->
        <a href={tutorials[0].url} class="tutorial-card featured">
          <div class="tutorial-thumb python-bg">
            <div class="tutorial-glow tg-python"></div>
            <div class="tutorial-thumb-code">
              <div>
                <span class="tc-kw">def</span>
                <span class="tc-plain">berechne_summe(zahlen):</span>
              </div>
              <div>
                &nbsp;&nbsp;<span class="tc-comment"># Liste durchlaufen</span>
              </div>
              <div>
                &nbsp;&nbsp;<span class="tc-kw">summe</span>
                <span class="tc-plain">= 0</span>
              </div>
              <div>
                &nbsp;&nbsp;<span class="tc-kw">for</span>
                <span class="tc-plain">z in zahlen:</span>
              </div>
              <div>
                &nbsp;&nbsp;&nbsp;&nbsp;<span class="tc-plain">summe += z</span>
              </div>
              <div>
                &nbsp;&nbsp;<span class="tc-kw">return</span>
                <span class="tc-plain">summe</span>
              </div>
            </div>
            <span class="tutorial-diff diff-beginner">Einsteiger</span>
          </div>
          <div class="tutorial-body">
            <div class="tutorial-cat py">🐍 Python</div>
            <h3 class="tutorial-title">{tutorials[0].title}</h3>
            <p class="tutorial-desc">{tutorials[0].desc}</p>
            <div class="tutorial-footer">
              <div class="tutorial-meta">{tutorials[0].meta}</div>
              <span class="tutorial-arrow">→</span>
            </div>
          </div>
        </a>

        <!-- Small card 1 -->
        <a href={tutorials[1].url} class="tutorial-card">
          <div class="tutorial-thumb godot-bg">
            <div class="tutorial-glow tg-godot"></div>
            <div class="tutorial-thumb-icon">🎮</div>
            <span class="tutorial-diff diff-basics">Grundlagen</span>
          </div>
          <div class="tutorial-body">
            <div class="tutorial-cat gd">🎮 Godot</div>
            <h3 class="tutorial-title">{tutorials[1].title}</h3>
            <p class="tutorial-desc">{tutorials[1].desc}</p>
            <div class="tutorial-footer">
              <div class="tutorial-meta">{tutorials[1].meta}</div>
              <span class="tutorial-arrow">→</span>
            </div>
          </div>
        </a>

        <!-- Small card 2 -->
        <a href={tutorials[2].url} class="tutorial-card" style="grid-column:1">
          <div class="tutorial-thumb python-bg">
            <div class="tutorial-glow tg-python"></div>
            <div class="tutorial-thumb-icon">🐍</div>
            <span class="tutorial-diff diff-beginner">Einsteiger</span>
          </div>
          <div class="tutorial-body">
            <div class="tutorial-cat py">🐍 Python</div>
            <h3 class="tutorial-title">{tutorials[2].title}</h3>
            <p class="tutorial-desc">{tutorials[2].desc}</p>
            <div class="tutorial-footer">
              <div class="tutorial-meta">{tutorials[2].meta}</div>
              <span class="tutorial-arrow">→</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ══════════ NEWSLETTER ══════════ -->
  <section class="newsletter-section" id="newsletter">
    <div class="container">
      <div class="newsletter-box">
        <div class="newsletter-text">
          <div class="newsletter-kicker">✉️ PhilsDevQuest Monthly</div>
          <h2 class="newsletter-headline">
            Einmal pro Monat<br />
            <em>das Wichtigste</em><br />
            direkt ins Postfach
          </h2>
          <ul class="newsletter-bullets">
            <li>Python- & Godot-Tipp des Monats</li>
            <li>Neue Tutorials direkt zum Lesen</li>
            <li>Kurze News aus der Dev-Welt</li>
            <li>Mein persönlicher DevLog-Fortschritt</li>
          </ul>
          <div class="newsletter-social-proof">
            <div class="newsletter-avatars">
              <div class="avatar">👾</div>
              <div class="avatar">🐍</div>
              <div class="avatar">🎮</div>
              <div class="avatar">⚡</div>
            </div>
            <span class="newsletter-social-text"
              >Schon <strong>einige Devs</strong> dabei — wirst du der nächste?</span
            >
          </div>
        </div>
        <div class="newsletter-form-wrap">
          <span class="newsletter-form-label">// Jetzt eintragen</span>
          <form class="newsletter-form" action="#" method="post">
            <input type="text" placeholder="Dein Vorname (optional)" />
            <input type="email" placeholder="deine@email.de" required />
            <button type="submit">Jetzt anmelden — kostenlos →</button>
          </form>
          <p class="newsletter-note">
            Kein Spam. Nur relevantes für Indie Game Dev Einsteiger.<br />
            Jederzeit mit einem Klick abmeldbar. DSGVO-konform.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ══════════ BLOG ══════════ -->
  <section class="section" style="padding-top:80px">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="section-label">Blog</div>
          <h2 class="section-title-display">
            Gedanken, Erfahrungen & Einblicke
          </h2>
        </div>
        <a href="/blog" class="section-link">Alle Artikel →</a>
      </div>
      <div class="blog-list">
        {
          blogPosts.map((post) => (
            <a href={post.url} class="blog-item">
              <div class="blog-date">
                <span class="blog-date-day">{post.day}</span>
                {post.month}
              </div>
              <div class="blog-content">
                <div class={`blog-tag ${post.tag}`}>{post.tagLabel}</div>
                <div class="blog-title">{post.title}</div>
                <div class="blog-excerpt">{post.excerpt}</div>
              </div>
              <div class="blog-arrow">→</div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ══════════ TOOLS ══════════ -->
  <section class="section" style="padding-top:80px;padding-bottom:96px">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="section-label">Tools & Ressourcen</div>
          <h2 class="section-title-display">Was ich täglich nutze</h2>
        </div>
        <a href="/tools" class="section-link">Alle Tools →</a>
      </div>
      <div class="tools-grid">
        {
          tools.map((tool) => (
            <div class="tool-card">
              <div class="tool-icon">{tool.icon}</div>
              <div class="tool-name">{tool.name}</div>
              <div class="tool-desc">{tool.desc}</div>
              <span class={`tool-tag ${tool.tag}`}>{tool.tagLabel}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Layout ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .section {
    padding: 96px 0;
  }
  .section-divider {
    height: 1px;
    background: var(--pdq-border-subtle);
    margin: 0;
  }

  /* ── Section labels ── */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--pdq-text-muted);
    margin-bottom: 12px;
  }
  .section-label::before {
    content: "";
    display: block;
    width: 20px;
    height: 1px;
    background: var(--pdq-text-disabled);
  }
  .section-title-display {
    font-family: "Fraunces", serif;
    font-size: 32px;
    font-weight: 300;
    letter-spacing: -0.5px;
    color: var(--pdq-text-primary);
  }
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 40px;
  }
  .section-link {
    font-size: 11px;
    color: var(--pdq-text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border: 1px solid var(--pdq-border-subtle);
    border-radius: 6px;
    transition: all 0.2s;
    text-decoration: none;
  }
  .section-link:hover {
    color: var(--pdq-cream);
    border-color: var(--pdq-border-default);
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes ticker {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.9;
    }
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  .fade-up-1 {
    animation: fadeUp 0.7s 0.1s ease both;
  }
  .fade-up-2 {
    animation: fadeUp 0.7s 0.25s ease both;
  }

  /* ── HERO ── */
  .hero {
    padding: 100px 0 80px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -100px;
    left: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      ellipse,
      rgba(193, 99, 79, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(193, 99, 79, 0.14);
    border: 1px solid rgba(193, 99, 79, 0.2);
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    color: var(--pdq-terracotta-light);
    letter-spacing: 0.5px;
    margin-bottom: 28px;
  }
  .hero-eyebrow::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pdq-terracotta);
    animation: pulse-glow 2s ease infinite;
  }
  .hero-headline {
    font-family: "Fraunces", serif;
    font-size: clamp(38px, 5vw, 54px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--pdq-text-primary);
    letter-spacing: -1px;
    margin-bottom: 24px;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--pdq-terracotta);
  }
  .hero-sub {
    font-size: 13px;
    color: var(--pdq-text-secondary);
    line-height: 1.8;
    margin-bottom: 36px;
    max-width: 420px;
  }
  .hero-form {
    display: flex;
    gap: 8px;
    max-width: 420px;
  }
  .hero-form input {
    flex: 1;
    background: var(--pdq-bg-elevated);
    border: 1px solid var(--pdq-border-default);
    border-radius: 6px;
    padding: 11px 16px;
    font-family: var(--pdq-font-mono);
    font-size: 12px;
    color: var(--pdq-text-primary);
    outline: none;
    transition: border-color 0.2s;
  }
  .hero-form input::placeholder {
    color: var(--pdq-text-disabled);
  }
  .hero-form input:focus {
    border-color: var(--pdq-terracotta);
  }
  .hero-form button {
    background: var(--pdq-orange);
    color: #12100e;
    border: none;
    border-radius: 6px;
    padding: 11px 20px;
    font-family: var(--pdq-font-mono);
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .hero-form button:hover {
    background: var(--pdq-orange-dark);
  }
  .hero-form-note {
    font-size: 10px;
    color: var(--pdq-text-disabled);
    margin-top: 10px;
  }

  /* Terminal */
  .hero-visual-wrap {
    position: relative;
  }
  .hero-badge-float {
    position: absolute;
    top: -16px;
    right: -16px;
    background: var(--pdq-bg-elevated);
    border: 1px solid var(--pdq-border-default);
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 11px;
    color: var(--pdq-text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    z-index: 2;
  }
  .hero-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #28c840;
    animation: pulse-glow 2s ease infinite;
  }
  .terminal {
    background: var(--pdq-bg-elevated);
    border: 1px solid var(--pdq-border-default);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.4);
  }
  .terminal-bar {
    background: var(--pdq-bg-subtle);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    gap: 8px;
