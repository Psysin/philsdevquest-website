---
// DATEI: src/pages/devlog/[...page].astro

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allEntries = await getCollection(
    "devlog",
    ({ data }: { data: any }) => !data.draft,
  );
  allEntries.sort(
    (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(allEntries, { pageSize: 10 });
}

const { page } = Astro.props as { page: Page<CollectionEntry<"devlog">> };

const projectColors: Record<string, string> = {
  "Python Lernreise": "project-python",
  Godot: "project-godot",
};

const projectIcons: Record<string, string> = {
  "Python Lernreise": "🐍",
  Godot: "🎮",
};

// Alle Projekte für Filter-Übersicht ermitteln
const allEntries = await getCollection(
  "devlog",
  ({ data }: { data: any }) => !data.draft,
);
const projects = [
  ...new Set(allEntries.map((e: any) => e.data.project)),
] as string[];
const countByProject: Record<string, number> = {};
for (const p of projects as string[]) {
  countByProject[p] = allEntries.filter(
    (e: any) => e.data.project === p,
  ).length;
}
---

<BaseLayout
  title={page.currentPage === 1
    ? "Devlog"
    : `Devlog — Seite ${page.currentPage}`}
  description="Mein Entwickler-Tagebuch: Python lernen, Godot-Projekte bauen — Schritt für Schritt dokumentiert."
>
  <main class="devlog-index">
    <div class="page-header">
      <span class="page-label">Entwickler-Tagebuch</span>
      <h1>Devlog</h1>
      <p class="page-subtitle">
        Was ich gerade lerne und baue — ehrlich dokumentiert. Fehler inklusive.
      </p>
    </div>

    <!-- Projekt-Übersicht -->
    <div class="project-filter">
      {
        projects.map((project: string) => (
          <div class={`project-pill ${projectColors[project] ?? ""}`}>
            <span class="project-icon">{projectIcons[project] ?? "📁"}</span>
            <span class="project-name">{project}</span>
            <span class="project-count">
              {countByProject[project]} Einträge
            </span>
          </div>
        ))
      }
    </div>

    <!-- Devlog Einträge -->
    <div class="devlog-list">
      {
        page.data.map((entry: any) => {
          const dateFormatted = entry.data.date.toLocaleDateString("de-DE", {
            day: "numeric",
            month: "long",
            year: "numeric",
          });
          const hasEpisode =
            entry.data.episode !== undefined && entry.data.episode !== null;
          return (
            <a href={`/devlog/${entry.slug}/`} class="devlog-card">
              <div class="devlog-card-left">
                {hasEpisode && (
                  <div class="episode-badge">
                    <span class="episode-label">Ep.</span>
                    <span class="episode-number">
                      {String(entry.data.episode).padStart(2, "0")}
                    </span>
                  </div>
                )}
                {!hasEpisode && (
                  <div class="episode-badge episode-single">
                    <span class="episode-label">—</span>
                  </div>
                )}
              </div>

              <div class="devlog-card-content">
                <div class="devlog-card-meta">
                  <span
                    class={`project-tag ${projectColors[entry.data.project] ?? ""}`}
                  >
                    {projectIcons[entry.data.project] ?? ""}{" "}
                    {entry.data.project}
                  </span>
                  <span class="devlog-date">{dateFormatted}</span>
                </div>
                <h2 class="devlog-card-title">{entry.data.title}</h2>
                <p class="devlog-card-desc">{entry.data.description}</p>
                {entry.data.tags.length > 0 && (
                  <div class="devlog-tags">
                    {entry.data.tags.slice(0, 4).map((tag: string) => (
                      <span class="tag-chip">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>

              <div class="devlog-card-arrow">→</div>
            </a>
          );
        })
      }
    </div>

    <!-- Pagination -->
    {
      page.lastPage > 1 && (
        <nav class="pagination" aria-label="Seitennavigation">
          <a
            href={page.url.prev ?? "#"}
            class={`pagination-btn ${!page.url.prev ? "disabled" : ""}`}
            aria-disabled={!page.url.prev}
          >
            ← Neuer
          </a>
          <div class="pagination-pages">
            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(
              (num) => (
                <a
                  href={num === 1 ? "/devlog/" : `/devlog/${num}/`}
                  class={`pagination-page ${num === page.currentPage ? "active" : ""}`}
                >
                  {num}
                </a>
              ),
            )}
          </div>
          <a
            href={page.url.next ?? "#"}
            class={`pagination-btn ${!page.url.next ? "disabled" : ""}`}
            aria-disabled={!page.url.next}
          >
            Älter →
          </a>
        </nav>
      )
    }
    {
      page.lastPage > 1 && (
        <p class="pagination-info">
          Seite {page.currentPage} von {page.lastPage} · {page.total} Einträge
          gesamt
        </p>
      )
    }
  </main>
</BaseLayout>

<style>
  .devlog-index {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  /* Header */
  .page-header {
    margin-bottom: 2rem;
  }
  .page-label {
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pdq-sand);
    display: block;
    margin-bottom: 0.5rem;
  }
  .page-header h1 {
    font-family: var(--pdq-font-mono);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--pdq-text-primary);
    margin: 0 0 0.75rem;
  }
  .page-subtitle {
    font-family: var(--pdq-font-mono);
    font-size: 0.95rem;
    color: var(--pdq-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Projekt-Übersicht */
  .project-filter {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .project-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--pdq-border-default);
    background: var(--pdq-bg-elevated);
    font-family: var(--pdq-font-mono);
    font-size: 0.82rem;
  }
  .project-python {
    border-color: rgba(193, 99, 79, 0.35);
    background: rgba(193, 99, 79, 0.08);
  }
  .project-godot {
    border-color: rgba(212, 169, 106, 0.35);
    background: rgba(212, 169, 106, 0.08);
  }
  .project-icon {
    font-size: 1rem;
  }
  .project-name {
    color: var(--pdq-text-primary);
    font-weight: 600;
  }
  .project-count {
    color: var(--pdq-text-muted);
    font-size: 0.75rem;
  }

  /* Devlog Liste */
  .devlog-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--pdq-border-default);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  /* Devlog Card */
  .devlog-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--pdq-bg-elevated);
    text-decoration: none;
    transition: background 0.15s;
    border-bottom: 1px solid var(--pdq-border-subtle);
  }
  .devlog-card:last-child {
    border-bottom: none;
  }
  .devlog-card:hover {
    background: var(--pdq-bg-overlay);
  }

  /* Episode-Nummer links */
  .devlog-card-left {
    flex-shrink: 0;
    padding-top: 0.15rem;
  }
  .episode-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 3rem;
    padding: 0.4rem 0;
    background: var(--pdq-bg-overlay);
    border: 1px solid var(--pdq-border-default);
    border-radius: 8px;
  }
  .episode-label {
    font-family: var(--pdq-font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pdq-text-muted);
  }
  .episode-number {
    font-family: var(--pdq-font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--pdq-sand);
    line-height: 1.2;
  }
  .episode-single .episode-label {
    font-size: 1rem;
    letter-spacing: 0;
  }

  /* Card Content */
  .devlog-card-content {
    flex: 1;
    min-width: 0;
  }
  .devlog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .project-tag {
    font-family: var(--pdq-font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
  }
  .project-tag.project-python {
    background: rgba(193, 99, 79, 0.12);
    color: var(--pdq-terracotta-light);
    border: 1px solid rgba(193, 99, 79, 0.3);
  }
  .project-tag.project-godot {
    background: rgba(212, 169, 106, 0.12);
    color: var(--pdq-sand);
    border: 1px solid rgba(212, 169, 106, 0.3);
  }
  .devlog-date {
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    color: var(--pdq-text-muted);
    margin-left: auto;
  }
  .devlog-card-title {
    font-family: var(--pdq-font-mono);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--pdq-text-primary);
    margin: 0 0 0.4rem;
    line-height: 1.4;
  }
  .devlog-card-desc {
    font-family: var(--pdq-font-mono);
    font-size: 0.875rem;
    color: var(--pdq-text-secondary);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }
  .devlog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag-chip {
    font-family: var(--pdq-font-mono);
    font-size: 0.7rem;
    color: var(--pdq-text-muted);
  }

  /* Pfeil rechts */
  .devlog-card-arrow {
    font-family: var(--pdq-font-mono);
    font-size: 1rem;
    color: var(--pdq-text-muted);
    flex-shrink: 0;
    padding-top: 0.15rem;
    transition:
      color 0.15s,
      transform 0.15s;
  }
  .devlog-card:hover .devlog-card-arrow {
    color: var(--pdq-sand);
    transform: translateX(3px);
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .pagination-btn {
    font-family: var(--pdq-font-mono);
    font-size: 0.85rem;
    color: var(--pdq-text-secondary);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--pdq-border-default);
    border-radius: 8px;
    background: var(--pdq-bg-elevated);
    transition: all 0.15s;
  }
  .pagination-btn:hover:not(.disabled) {
    background: var(--pdq-bg-overlay);
    color: var(--pdq-sand);
    border-color: var(--pdq-sand);
  }
  .pagination-btn.disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }
  .pagination-pages {
    display: flex;
    gap: 0.35rem;
  }
  .pagination-page {
    font-family: var(--pdq-font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--pdq-text-secondary);
    text-decoration: none;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--pdq-border-default);
    border-radius: 8px;
    background: var(--pdq-bg-elevated);
    transition: all 0.15s;
  }
  .pagination-page:hover {
    background: var(--pdq-bg-overlay);
    color: var(--pdq-sand);
    border-color: var(--pdq-sand);
  }
  .pagination-page.active {
    background: var(--pdq-sand);
    color: var(--pdq-bg-base);
    border-color: var(--pdq-sand);
  }
  .pagination-info {
    font-family: var(--pdq-font-mono);
    font-size: 0.78rem;
    color: var(--pdq-text-muted);
    text-align: center;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .devlog-card {
      gap: 0.875rem;
    }
    .devlog-date {
      margin-left: 0;
      width: 100%;
    }
    .episode-badge {
      width: 2.5rem;
    }
    .episode-number {
      font-size: 0.95rem;
    }
  }
</style>
