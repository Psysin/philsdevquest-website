---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allDevlog = await getCollection("devlog", ({ data }) => !data.draft);
allDevlog.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(date: Date) {
  const months = ["Jan","Feb","Mär","Apr","Mai","Jun","Jul","Aug","Sep","Okt","Nov","Dez"];
  return `${date.getDate()}. ${months[date.getMonth()]} ${date.getFullYear()}`;
}
---

<BaseLayout
  title="Devlog"
  description="Meine Reise, Folge für Folge. Zwei Richtungen — Python und Godot. Chronologisch, mit Code."
>

<section class="devlog-hero">
  <div class="container">
    <div class="section-eyebrow">Devlog</div>
    <h1 class="section-title">Meine Reise, <span class="muted">Folge für Folge.</span></h1>
    <p class="section-sub">Zwei Richtungen — Python und Godot. Chronologisch, mit Code. Du siehst, was klappt und was nicht.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="section-eyebrow" style="margin-bottom: 20px;">Alle Folgen</div>
    {allDevlog.length > 0 ? (
      <div class="devlog-list">
        {allDevlog.map((entry) => (
          <a href={`/devlog/${entry.slug}`} class={`devlog-row ${entry.data.project === 'Godot' ? 'devlog-row--godot' : ''}`}>
            <div class="devlog-num">
              <span class="track-dot"></span>
              {entry.data.project === 'Python Lernreise' ? 'Python' : 'Godot'}
            </div>
            <div class="devlog-tt">{entry.data.title}</div>
            <div class="devlog-date">{formatDate(entry.data.date)}</div>
          </a>
        ))}
      </div>
    ) : (
      <div class="devlog-empty">Mehr Folgen folgen bald.</div>
    )}
  </div>
</section>

</BaseLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
  section { padding: 80px 0; }
  .devlog-hero { padding-bottom: 0; }

  .section-eyebrow { font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pdq-terracotta); margin-bottom: 16px; }
  .section-title { font-weight: 600; font-size: clamp(28px, 4vw, 48px); line-height: 1.08; letter-spacing: -0.025em; color: var(--pdq-text-primary); max-width: 22ch; }
  .section-title .muted { color: var(--pdq-text-muted); }
  .section-sub { font-size: 18px; color: var(--pdq-text-secondary); line-height: 1.6; max-width: 560px; margin-top: 20px; }

  .devlog-list { display: flex; flex-direction: column; }
  .devlog-row {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 22px 0;
    border-bottom: 1px solid var(--pdq-border-subtle);
    text-decoration: none;
    color: inherit;
    transition: padding-left .2s;
  }
  .devlog-row:first-child { border-top: 1px solid var(--pdq-border-subtle); }
  .devlog-row:hover { padding-left: 8px; color: inherit; }

  .devlog-num { font-size: 12px; color: var(--pdq-text-muted); letter-spacing: 0.05em; display: flex; align-items: center; gap: 8px; }
  .track-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--pdq-terracotta); flex-shrink: 0; }
  .devlog-row--godot .track-dot { background: var(--pdq-sand); }
  .devlog-tt { font-weight: 500; font-size: 16px; color: var(--pdq-text-primary); letter-spacing: -0.005em; }
  .devlog-date { font-size: 12px; color: var(--pdq-text-muted); white-space: nowrap; }
  .devlog-empty { font-size: 14px; color: var(--pdq-text-muted); text-align: center; padding: 48px 0; }

  @media (max-width: 720px) {
    .container { padding: 0 20px; }
    .devlog-row { grid-template-columns: 1fr; gap: 6px; }
    .devlog-date { display: none; }
  }
</style>
