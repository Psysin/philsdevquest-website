---
// DATEI: src/pages/devlog/[slug].astro

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection(
    "devlog",
    ({ data }: { data: any }) => !data.draft,
  );
  return entries.map((entry: CollectionEntry<"devlog">) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"devlog"> };
const { Content } = await entry.render();

const dateFormatted = entry.data.date.toLocaleDateString("de-DE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const projectColors: Record<string, string> = {
  "Python Lernreise": "project-python",
  Godot: "project-godot",
};
const projectIcons: Record<string, string> = {
  "Python Lernreise": "🐍",
  Godot: "🎮",
};

// Vorherigen & nächsten Eintrag des gleichen Projekts ermitteln
const allEntries = await getCollection(
  "devlog",
  ({ data }: { data: any }) => !data.draft,
);
const sameProject = allEntries
  .filter(
    (e: any) =>
      e.data.project === entry.data.project && e.data.episode !== undefined,
  )
  .sort((a: any, b: any) => a.data.episode - b.data.episode);

const currentIdx = sameProject.findIndex((e: any) => e.slug === entry.slug);
const prevEntry = currentIdx > 0 ? sameProject[currentIdx - 1] : null;
const nextEntry =
  currentIdx < sameProject.length - 1 ? sameProject[currentIdx + 1] : null;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <main class="devlog-post">
    <!-- Zurück-Link -->
    <a href="/devlog/" class="back-link">← Alle Devlog-Einträge</a>

    <!-- Header -->
    <header class="post-header">
      <div class="post-meta">
        <span class={`project-tag ${projectColors[entry.data.project] ?? ""}`}>
          {projectIcons[entry.data.project] ?? ""}
          {entry.data.project}
        </span>
        {
          entry.data.episode !== undefined && (
            <span class="episode-tag">Episode {entry.data.episode}</span>
          )
        }
        <span class="post-date">{dateFormatted}</span>
      </div>

      <h1 class="post-title">{entry.data.title}</h1>
      <p class="post-description">{entry.data.description}</p>

      {
        entry.data.tags.length > 0 && (
          <div class="post-tags">
            {entry.data.tags.map((tag: string) => (
              <span class="tag-chip">#{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <!-- Beitragsbild -->
    {
      entry.data.og_image && (
        <div class="post-image">
          <img
            src={entry.data.og_image}
            alt={entry.data.title}
            loading="lazy"
          />
        </div>
      )
    }

    <!-- Trennlinie -->
    <div class="post-divider"></div>

    <!-- Artikel-Inhalt -->
    <article class="post-content prose">
      <Content />
    </article>

    <!-- Episode-Navigation (nur wenn Projekt-Serie mit Episoden) -->
    {
      (prevEntry || nextEntry) && (
        <nav class="episode-nav">
          <span class="episode-nav-label">
            {projectIcons[entry.data.project] ?? ""} {entry.data.project} —
            weitere Einträge
          </span>
          <div class="episode-nav-links">
            {prevEntry ? (
              <a
                href={`/devlog/${prevEntry.slug}/`}
                class="episode-nav-btn prev"
              >
                <span class="nav-arrow">←</span>
                <span class="nav-info">
                  <span class="nav-ep">Episode {prevEntry.data.episode}</span>
                  <span class="nav-title">{prevEntry.data.title}</span>
                </span>
              </a>
            ) : (
              <div />
            )}
            {nextEntry ? (
              <a
                href={`/devlog/${nextEntry.slug}/`}
                class="episode-nav-btn next"
              >
                <span class="nav-info">
                  <span class="nav-ep">Episode {nextEntry.data.episode}</span>
                  <span class="nav-title">{nextEntry.data.title}</span>
                </span>
                <span class="nav-arrow">→</span>
              </a>
            ) : (
              <div />
            )}
          </div>
        </nav>
      )
    }

    <!-- Zurück-Link unten -->
    <div class="post-footer">
      <a href="/devlog/" class="back-link">← Zurück zum Devlog</a>
    </div>
  </main>
</BaseLayout>

<style>
  .devlog-post {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  /* Zurück-Link */
  .back-link {
    font-family: var(--pdq-font-mono);
    font-size: 0.82rem;
    color: var(--pdq-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--pdq-sand);
  }

  /* Header */
  .post-header {
    margin-bottom: 2rem;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .project-tag {
    font-family: var(--pdq-font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }
  .project-tag.project-python {
    background: rgba(193, 99, 79, 0.12);
    color: var(--pdq-terracotta-light);
    border: 1px solid rgba(193, 99, 79, 0.3);
  }
  .project-tag.project-godot {
    background: rgba(212, 169, 106, 0.12);
    color: var(--pdq-sand);
    border: 1px solid rgba(212, 169, 106, 0.3);
  }

  .episode-tag {
    font-family: var(--pdq-font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: rgba(212, 169, 106, 0.08);
    color: var(--pdq-sand);
    border: 1px solid rgba(212, 169, 106, 0.2);
  }

  .post-date {
    font-family: var(--pdq-font-mono);
    font-size: 0.78rem;
    color: var(--pdq-text-muted);
    margin-left: auto;
  }

  .post-title {
    font-family: var(--pdq-font-mono);
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--pdq-text-primary);
    line-height: 1.3;
    margin: 0 0 0.75rem;
  }
  .post-description {
    font-family: var(--pdq-font-mono);
    font-size: 1rem;
    color: var(--pdq-text-secondary);
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-chip {
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    color: var(--pdq-text-muted);
  }

  /* Beitragsbild */
  .post-image {
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--pdq-border-default);
  }
  .post-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Trennlinie */
  .post-divider {
    height: 1px;
    background: var(--pdq-border-default);
    margin: 2rem 0;
  }

  /* Artikel-Inhalt */
  .prose {
    font-family: var(--pdq-font-mono);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--pdq-text-secondary);
  }
  .prose :global(h2) {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--pdq-text-primary);
    margin: 2.5rem 0 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--pdq-text-primary);
    margin: 2rem 0 0.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1.25rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25rem 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.35rem;
  }
  .prose :global(strong) {
    color: var(--pdq-text-primary);
    font-weight: 700;
  }
  .prose :global(code) {
    font-family: var(--pdq-font-mono);
    font-size: 0.875em;
    background: var(--pdq-bg-overlay);
    border: 1px solid var(--pdq-border-default);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--pdq-sand);
  }
  .prose :global(pre) {
    background: var(--pdq-bg-elevated);
    border: 1px solid var(--pdq-border-default);
    border-radius: 10px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--pdq-text-primary);
    font-size: 0.875rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--pdq-sand);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--pdq-text-muted);
    font-style: italic;
  }
  .prose :global(a) {
    color: var(--pdq-sand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    color: var(--pdq-cream);
  }
  .prose :global(img) {
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--pdq-border-default);
    margin: 1.5rem 0;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--pdq-border-default);
    margin: 2.5rem 0;
  }

  /* Episode-Navigation */
  .episode-nav {
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--pdq-bg-elevated);
    border: 1px solid var(--pdq-border-default);
    border-radius: 12px;
  }
  .episode-nav-label {
    font-family: var(--pdq-font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pdq-text-muted);
    display: block;
    margin-bottom: 1rem;
  }
  .episode-nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .episode-nav-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--pdq-bg-overlay);
    border: 1px solid var(--pdq-border-default);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .episode-nav-btn:hover {
    border-color: var(--pdq-sand);
    background: rgba(212, 169, 106, 0.06);
  }
  .episode-nav-btn.next {
    justify-content: flex-end;
    text-align: right;
  }
  .nav-arrow {
    font-family: var(--pdq-font-mono);
    font-size: 1rem;
    color: var(--pdq-sand);
    flex-shrink: 0;
  }
  .nav-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .nav-ep {
    font-family: var(--pdq-font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pdq-sand);
  }
  .nav-title {
    font-family: var(--pdq-font-mono);
    font-size: 0.82rem;
    color: var(--pdq-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Footer */
  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--pdq-border-default);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .post-title {
      font-size: 1.5rem;
    }
    .post-date {
      margin-left: 0;
      width: 100%;
    }
    .episode-nav-links {
      grid-template-columns: 1fr;
    }
    .nav-title {
      white-space: normal;
    }
  }
</style>
