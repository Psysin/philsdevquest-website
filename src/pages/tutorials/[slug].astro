---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const tutorials = await getCollection("tutorials", ({ data }) => !data.draft);
  return tutorials.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, category, difficulty, date, readTime } = entry.data;

// Nächstes Tutorial ermitteln (nach Datum, gleiche oder beliebige Kategorie)
const allTutorials = (
  await getCollection("tutorials", ({ data }) => !data.draft)
).sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const currentIndex = allTutorials.findIndex((t) => t.slug === entry.slug);
const nextTutorial = allTutorials[currentIndex + 1] ?? null;

const difficultyLabel: Record<string, string> = {
  einsteiger: "Einsteiger",
  grundlagen: "Grundlagen",
  fortgeschritten: "Fortgeschritten",
};

const formattedDate = date.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={title} description={description}>
  <article class="tutorial">
    <div class="tutorial__inner">
      <!-- ─── BREADCRUMB ─── -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Start</a>
        <span class="breadcrumb__sep">›</span>
        <a href="/tutorials/" class="breadcrumb__link">Tutorials</a>
        <span class="breadcrumb__sep">›</span>
        <span class="breadcrumb__current">{title}</span>
      </nav>

      <!-- ─── AD POSITION 1 ─── (zwischen Breadcrumb und Badges) -->
      <AdSlot slotId="5030653446" />

      <!-- ─── HEADER ─── -->
      <header class="tutorial__header">
        <!-- Badges -->
        <div class="tutorial__badges">
          <span class={`badge badge--${category}`}>
            {category === "python" ? "🐍 Python" : "🎮 Godot"}
          </span>
          <span class={`badge badge--diff badge--diff-${difficulty}`}>
            {difficultyLabel[difficulty]}
          </span>
        </div>

        <!-- Titel -->
        <h1 class="tutorial__title">{title}</h1>

        <!-- Meta -->
        <div class="tutorial__meta">
          <span>📅 {formattedDate}</span>
          <span class="tutorial__meta-sep">·</span>
          <span>⏱ {readTime}</span>
        </div>
      </header>

      <!-- ─── CONTENT ─── -->
      <div class="tutorial__content prose">
        <Content />
      </div>

      <!-- ─── AD POSITIONEN 2 + 3 via JavaScript ─── -->
      <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
          const publisherId = "ca-pub-1972800950201366";

          function createAd(slotId) {
            const wrapper = document.createElement("div");
            wrapper.className = "ad-slot ad-slot--injected";
            wrapper.innerHTML = `
              <ins class="adsbygoogle"
                style="display:block"
                data-ad-client="${publisherId}"
                data-ad-slot="${slotId}"
                data-ad-format="auto"
                data-full-width-responsive="true">
              </ins>
            `;
            return wrapper;
          }

          // ── POSITION 2: Direkt VOR der h2 "Übungen" ──────────────────────
          document.querySelectorAll(".tutorial__content h2").forEach((h2) => {
            if (h2.textContent.trim() === "Übungen") {
              const ad = createAd("1091408436");
              h2.parentNode.insertBefore(ad, h2);
              (window.adsbygoogle = window.adsbygoogle || []).push({});
            }
          });

          // ── POSITION 3: Nach dem letzten <details> (Lösung anzeigen) ─────
          const allDetails = document.querySelectorAll(
            ".tutorial__content details",
          );
          if (allDetails.length > 0) {
            const lastDetails = allDetails[allDetails.length - 1];
            const ad = createAd("7361449107");
            lastDetails.parentNode.insertBefore(ad, lastDetails.nextSibling);
            (window.adsbygoogle = window.adsbygoogle || []).push({});
          }
        });
      </script>

      <!-- ─── NEXT TUTORIAL ─── -->
      {
        nextTutorial && (
          <div class="tutorial__next">
            <p class="tutorial__next-label">Weiter lernen →</p>
            <a
              href={`/tutorials/${nextTutorial.slug}`}
              class="tutorial__next-card"
            >
              <div class="tutorial__next-meta">
                <span class={`badge badge--${nextTutorial.data.category}`}>
                  {nextTutorial.data.category === "python"
                    ? "🐍 Python"
                    : "🎮 Godot"}
                </span>
                <span
                  class={`badge badge--diff badge--diff-${nextTutorial.data.difficulty}`}
                >
                  {difficultyLabel[nextTutorial.data.difficulty]}
                </span>
              </div>
              <p class="tutorial__next-title">{nextTutorial.data.title}</p>
              <p class="tutorial__next-desc">{nextTutorial.data.description}</p>
            </a>
          </div>
        )
      }

      <!-- ─── ZURÜCK-LINK ─── -->
      <div class="tutorial__back">
        <a href="/tutorials/" class="back-link">← Alle Tutorials</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  /* ── LAYOUT ── */
  .tutorial {
    padding: 3rem 1.5rem 5rem;
  }
  .tutorial__inner {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── BREADCRUMB ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    font-family: var(--pdq-font-mono);
    font-size: 0.78rem;
    color: var(--pdq-text-muted);
  }
  .breadcrumb__link {
    color: var(--pdq-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumb__link:hover {
    color: var(--pdq-orange);
  }
  .breadcrumb__sep {
    opacity: 0.5;
  }
  .breadcrumb__current {
    color: var(--pdq-text-secondary);
  }

  /* ── HEADER ── */
  .tutorial__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--pdq-border-subtle);
  }

  .tutorial__badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  /* Badges */
  .badge {
    font-family: var(--pdq-font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.2em 0.65em;
    border-radius: 4px;
  }
  .badge--python {
    background: rgba(193, 99, 79, 0.15);
    color: var(--pdq-terracotta-light);
    border: 1px solid rgba(193, 99, 79, 0.3);
  }
  .badge--godot {
    background: rgba(212, 169, 106, 0.15);
    color: var(--pdq-sand-light);
    border: 1px solid rgba(212, 169, 106, 0.3);
  }
  .badge--diff {
    background: var(--pdq-bg-subtle);
    color: var(--pdq-text-muted);
    border: 1px solid var(--pdq-border-subtle);
  }
  .badge--diff-einsteiger {
    color: #6db88a;
    border-color: rgba(109, 184, 138, 0.3);
    background: rgba(109, 184, 138, 0.08);
  }
  .badge--diff-grundlagen {
    color: var(--pdq-sand);
    border-color: rgba(212, 169, 106, 0.3);
    background: rgba(212, 169, 106, 0.08);
  }
  .badge--diff-fortgeschritten {
    color: var(--pdq-terracotta-light);
    border-color: rgba(193, 99, 79, 0.3);
    background: rgba(193, 99, 79, 0.08);
  }

  .tutorial__title {
    font-family: var(--pdq-font-mono);
    
    font-size: clamp(1.9rem, 5vw, 3rem);
    font-weight: 400;
    color: var(--pdq-text-primary);
    line-height: 1.15;
    margin: 0;
  }

  .tutorial__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--pdq-font-mono);
    font-size: 0.82rem;
    color: var(--pdq-text-muted);
  }
  .tutorial__meta-sep {
    opacity: 0.4;
  }

  /* ── MARKDOWN CONTENT ── */
  .prose {
    font-family: var(--pdq-font-mono);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--pdq-text-secondary);
  }

  .prose :global(h2) {
    font-family: var(--pdq-font-mono);
    
    font-size: 1.65rem;
    font-weight: 400;
    color: var(--pdq-text-primary);
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--pdq-border-subtle);
  }

  .prose :global(h3) {
    font-family: var(--pdq-font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--pdq-text-primary);
    margin: 2rem 0 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.2rem;
  }

  .prose :global(a) {
    color: var(--pdq-orange);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255, 107, 53, 0.4);
    transition: text-decoration-color 0.15s;
  }
  .prose :global(a:hover) {
    text-decoration-color: var(--pdq-orange);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }
  .prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose :global(li::marker) {
    color: var(--pdq-terracotta);
  }

  .prose :global(strong) {
    color: var(--pdq-text-primary);
    font-weight: 700;
  }

  .prose :global(em) {
    color: var(--pdq-sand);
    
  }

  /* Inline-Code */
  .prose :global(code:not(pre code)) {
    font-family: var(--pdq-font-mono);
    font-size: 0.88em;
    background: var(--pdq-bg-overlay);
    color: var(--pdq-terracotta-light);
    border: 1px solid var(--pdq-border-default);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  /* Code-Blöcke */
  .prose :global(pre) {
    background: var(--pdq-bg-overlay);
    border: 1px solid var(--pdq-border-default);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    line-height: 1.65;
  }
  .prose :global(pre code) {
    font-family: var(--pdq-font-mono);
    font-size: 0.875rem;
    background: transparent;
    border: none;
    padding: 0;
    color: var(--pdq-cream);
  }

  /* Blockquote */
  .prose :global(blockquote) {
    border-left: 3px solid var(--pdq-terracotta);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--pdq-bg-overlay);
    border-radius: 0 6px 6px 0;
    color: var(--pdq-text-muted);
  }

  /* Trennlinie */
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--pdq-border-subtle);
    margin: 2.5rem 0;
  }

  /* ── AD SLOTS ── */
  :global(.ad-slot) {
    width: 100%;
    min-height: 90px;
  }
  :global(.ad-slot--injected) {
    margin: 2rem 0;
  }

  /* ── NÄCHSTES TUTORIAL ── */
  .tutorial__next-label {
    font-family: var(--pdq-font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pdq-text-muted);
    margin-bottom: 0.75rem;
  }

  .tutorial__next-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    border: 1px solid var(--pdq-border-default);
    background: var(--pdq-bg-elevated);
    text-decoration: none;
    transition:
      border-color 0.18s,
      background 0.18s,
      transform 0.18s;
  }
  .tutorial__next-card:hover {
    border-color: var(--pdq-orange);
    background: var(--pdq-bg-overlay);
    transform: translateX(4px);
  }

  .tutorial__next-meta {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tutorial__next-title {
    font-family: "Caveat", cursive;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--pdq-text-primary);
    margin: 0;
  }

  .tutorial__next-desc {
    font-family: var(--pdq-font-mono);
    font-size: 0.83rem;
    color: var(--pdq-text-muted);
    margin: 0;
  }

  /* ── ZURÜCK ── */
  .tutorial__back {
    padding-top: 0.5rem;
  }

  .back-link {
    font-family: var(--pdq-font-mono);
    font-size: 0.85rem;
    color: var(--pdq-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--pdq-orange);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    .tutorial__title {
      font-size: 1.9rem;
    }
  }
</style>
