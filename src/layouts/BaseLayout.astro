---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  type?: "website" | "article";
}

const {
  title = "PhilsDevQuest",
  description = "Python und Godot für Einsteiger — Tutorials, Tipps und Tools von Anfänger zu Anfänger.",
  ogImage = "/images/og-default.png",
  type = "website",
} = Astro.props;

const siteUrl = "https://philsdevquest.de";
const canonicalUrl =
  Astro.props.canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const fullTitle =
  title === "PhilsDevQuest" ? title : `${title} – PhilsDevQuest`;
const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : `${siteUrl}${ogImage}`;
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="google-site-verification"
      content="KXA89P_dH-27ddHp6N59ASrzTGj4x20HmooGFVV8Tzg"
    />

    <!-- ─── Favicons ─────────────────────────────────────── -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- ─── SEO Basis ────────────────────────────────────── -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <!-- ─── Open Graph (Social Media Previews) ───────────── -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="PhilsDevQuest" />
    <meta property="og:locale" content="de_DE" />

    <!-- ─── Twitter / X Card ─────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@PhilsDevQuest" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- ─── Google Fonts ─────────────────────────────────── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Fraunces:ital,opsz,wght@1,9..144,300;1,9..144,400;1,9..144,500;1,9..144,600&family=Caveat:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
